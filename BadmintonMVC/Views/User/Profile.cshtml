@{
    ViewData["Title"] = "Hồ sơ";
    Layout = "_UserLayout";
}

@{
    var profile = ViewBag.Profile;
    var loyaltyPoints = ViewBag.LoyaltyPoints ?? "0";
    string displayName = ViewBag.DisplayName ?? "Ngườii dùng";
    string phone = ViewBag.UserPhone ?? Context.Session.GetString("UserPhone") ?? "Chưa cập nhật";
    string email = ViewBag.UserEmail ?? Context.Session.GetString("UserEmail") ?? "Chưa cập nhật";
    string userRole = Context.Session.GetString("UserRole") ?? "Customer";
    
    // Get level info
    int pts = 0;
    if (loyaltyPoints != null) {
        int.TryParse(loyaltyPoints.ToString(), out pts);
    }
    var level = "";
    var levelColor = "#b45309";
    var nextLevel = 500;
    var progress = (pts / 500.0) * 100;
    
    if (pts >= 5000) {
        level = "💎 Kim Cương";
        levelColor = "#06b6d4";
        nextLevel = 0;
        progress = 100;
    } else if (pts >= 2000) {
        level = "🥇 Vàng";
        levelColor = "#f59e0b";
        nextLevel = 5000;
        progress = ((pts - 2000) / 3000.0) * 100;
    } else if (pts >= 500) {
        level = "🥈 Bạc";
        levelColor = "#64748b";
        nextLevel = 2000;
        progress = ((pts - 500) / 1500.0) * 100;
    } else {
        level = "🥉 Đồng";
        levelColor = "#b45309";
        nextLevel = 500;
        progress = (pts / 500.0) * 100;
    }
}

<div class="profile-page">
    <!-- HERO CARD -->
    <div class="hero-card">
        <div class="hero-card-bg"></div>
        <div class="hero-card-content">
            <div class="avatar-ring">
                <div class="avatar-large">@(displayName.Length > 0 ? displayName[0] : 'U')</div>
            </div>
            <div>
                <h1 class="hero-card-name">@displayName</h1>
                <div class="hero-card-meta">
                    <span class="level-badge" style="background: @(levelColor)22; color: @(levelColor); border-color: @(levelColor)55">
                        @level
                    </span>
                    <span class="status-active">● Đang hoạt động</span>
                </div>
            </div>
        </div>
    </div>

    <div class="profile-grid">
        <!-- PERSONAL INFO -->
        <section class="profile-card">
            <div class="profile-card-header">
                <span class="profile-card-icon">👤</span>
                <h2 class="profile-card-title">Thông tin cá nhân</h2>
            </div>
            <div class="info-list">
                <div class="info-row">
                    <span class="info-label">Họ & Tên</span>
                    <span class="info-value">@displayName</span>
                </div>
                <div class="info-row">
                    <span class="info-label">Số điện thoại</span>
                    <span class="info-value">@phone</span>
                </div>
                <div class="info-row">
                    <span class="info-label">Email</span>
                    <span class="info-value">@email</span>
                </div>
                <div class="info-row">
                    <span class="info-label">Vai trò</span>
                    <span class="info-value">@userRole</span>
                </div>
            </div>
        </section>

        <!-- LOYALTY POINTS -->
        <section class="profile-card">
            <div class="profile-card-header">
                <span class="profile-card-icon">⭐</span>
                <h2 class="profile-card-title">Điểm tích lũy</h2>
            </div>
            <div class="points-display">
                <div class="points-big">@pts.ToString("N0")</div>
                <div class="points-label">điểm tích lũy</div>
                <div class="points-hint">Mỗi 100.000đ chi tiêu = 1 điểm</div>
            </div>
            <div style="margin-top: 16px;">
                <div style="display: flex; justify-content: space-between; margin-bottom: 8px;">
                    <span style="color: @(levelColor); font-weight: 700;">@level</span>
                    @if (nextLevel > 0)
                    {
                        <span style="color: #64748b;">→ @nextLevel.ToString("N0") điểm</span>
                    }
                </div>
                <div style="background: #e2e8f0; border-radius: 8px; height: 8px; overflow: hidden;">
                    <div style="width: @(Math.Min(progress, 100))%; background: @(levelColor); height: 100%;"></div>
                </div>
                @if (nextLevel > 0)
                {
                    <p style="margin: 8px 0 0; font-size: 0.8rem; color: #64748b;">
                        Còn <strong>@((nextLevel - pts).ToString("N0"))</strong> điểm để lên hạng
                    </p>
                }
                else
                {
                    <p style="margin: 8px 0 0; font-size: 0.8rem; color: #64748b;">
                        🎉 Bạn đã đạt cấp độ cao nhất!
                    </p>
                }
            </div>
            <div style="margin-top: 20px; padding: 16px; background: #f1f5f9; border-radius: 12px;">
                <p style="margin: 0 0 8px; font-weight: 700; color: #0f172a;">Quyền lợi thành viên</p>
                <ul style="margin: 0; padding-left: 20px; font-size: 0.85rem; color: #64748b;">
                    <li>✅ Tích điểm mỗi lần thanh toán</li>
                    <li>✅ Ưu tiên đặt sân giờ cao điểm</li>
                    @if (pts >= 500)
                    {
                        <li>✅ Hạng Bạc: Ưu đãi đặc biệt</li>
                    }
                    @if (pts >= 2000)
                    {
                        <li>✅ Hạng Vàng: Giảm 10% phí sân</li>
                    }
                    @if (pts >= 5000)
                    {
                        <li>✅ Hạng Kim Cương: Ưu tiên tối đa</li>
                    }
                </ul>
            </div>
        </section>
    </div>
</div>
