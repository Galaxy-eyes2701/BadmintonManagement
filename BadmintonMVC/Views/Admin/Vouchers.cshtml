@{
    ViewData["Title"] = "Quản lý Voucher";
    ViewData["Page"]  = "vouchers";
    Layout = "_AdminLayout";
}

<div class="p-4">
    <!-- STATS -->
    <div class="row g-3 mb-4">
        <div class="col-md-4">
            <div class="card border-0 shadow-sm" style="border-left:4px solid #0f766e!important">
                <div class="card-body d-flex align-items-center gap-3">
                    <span style="font-size:32px">🎟️</span>
                    <div>
                        <div class="text-muted small fw-semibold">TỔNG VOUCHER</div>
                        <div class="fw-black fs-4" id="statTotal">—</div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card border-0 shadow-sm" style="border-left:4px solid #10b981!important">
                <div class="card-body d-flex align-items-center gap-3">
                    <span style="font-size:32px">✅</span>
                    <div>
                        <div class="text-muted small fw-semibold">CÒN HIỆU LỰC</div>
                        <div class="fw-black fs-4 text-success" id="statActive">—</div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card border-0 shadow-sm" style="border-left:4px solid #f59e0b!important">
                <div class="card-body d-flex align-items-center gap-3">
                    <span style="font-size:32px">⏰</span>
                    <div>
                        <div class="text-muted small fw-semibold">HẾT HẠN</div>
                        <div class="fw-black fs-4 text-warning" id="statExpired">—</div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- TOOLBAR -->
    <div class="d-flex gap-3 mb-3 flex-wrap">
        <input type="text" id="searchInput" class="form-control"
               placeholder="🔍 Tìm mã voucher..." style="max-width:280px" oninput="renderTable()"/>
        <select id="statusFilter" class="form-select" style="width:180px" onchange="renderTable()">
            <option value="">Tất cả</option>
            <option value="active">✅ Còn hiệu lực</option>
            <option value="expired">⏰ Hết hạn</option>
        </select>
        <button class="btn btn-primary ms-auto" onclick="openCreate()">+ Thêm voucher</button>
    </div>

    <!-- BẢNG -->
    <div class="card shadow-sm">
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead style="background:linear-gradient(135deg,#0d5e58,#0f766e);color:white">
                    <tr>
                        <th>#ID</th>
                        <th>Mã voucher</th>
                        <th>Giảm giá</th>
                        <th>Giới hạn dùng</th>
                        <th>Ngày hết hạn</th>
                        <th>Trạng thái</th>
                        <th>Thao tác</th>
                    </tr>
                </thead>
                <tbody id="tableBody">
                    <tr><td colspan="7" class="text-center p-4 text-muted">Đang tải...</td></tr>
                </tbody>
            </table>
        </div>
    </div>
</div>

<!-- MODAL THÊM/SỬA -->
<div class="modal fade" id="voucherModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header" style="background:linear-gradient(135deg,#f0fdf9,#e6faf8)">
                <h5 class="modal-title" id="modalTitle">🎟️ Thêm voucher</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <input type="hidden" id="editId"/>
                <div class="mb-3">
                    <label class="form-label fw-semibold">Mã voucher *</label>
                    <input type="text" id="vCode" class="form-control"
                           placeholder="VD: SUMMER2025" oninput="this.value=this.value.toUpperCase()"/>
                </div>
                <div class="row g-3 mb-3">
                    <div class="col">
                        <label class="form-label fw-semibold">Số tiền giảm (đ) *</label>
                        <input type="number" id="vDiscount" class="form-control" min="0" placeholder="50000"/>
                        <!-- Quick fill -->
                        <div class="d-flex gap-1 mt-1 flex-wrap">
                            <button type="button" class="btn btn-outline-secondary btn-sm"
                                    onclick="document.getElementById('vDiscount').value=20000">20k</button>
                            <button type="button" class="btn btn-outline-secondary btn-sm"
                                    onclick="document.getElementById('vDiscount').value=50000">50k</button>
                            <button type="button" class="btn btn-outline-secondary btn-sm"
                                    onclick="document.getElementById('vDiscount').value=100000">100k</button>
                            <button type="button" class="btn btn-outline-secondary btn-sm"
                                    onclick="document.getElementById('vDiscount').value=200000">200k</button>
                        </div>
                    </div>
                    <div class="col">
                        <label class="form-label fw-semibold">Giới hạn dùng *</label>
                        <input type="number" id="vLimit" class="form-control" min="1" placeholder="100"/>
                        <div class="d-flex gap-1 mt-1 flex-wrap">
                            <button type="button" class="btn btn-outline-secondary btn-sm"
                                    onclick="document.getElementById('vLimit').value=10">10</button>
                            <button type="button" class="btn btn-outline-secondary btn-sm"
                                    onclick="document.getElementById('vLimit').value=50">50</button>
                            <button type="button" class="btn btn-outline-secondary btn-sm"
                                    onclick="document.getElementById('vLimit').value=100">100</button>
                        </div>
                    </div>
                </div>
                <div class="mb-3">
                    <label class="form-label fw-semibold">Ngày hết hạn *</label>
                    <input type="date" id="vExpiry" class="form-control"/>
                    <div class="d-flex gap-1 mt-1 flex-wrap">
                        <button type="button" class="btn btn-outline-secondary btn-sm" onclick="addDays(7)">+7 ngày</button>
                        <button type="button" class="btn btn-outline-secondary btn-sm" onclick="addDays(30)">+1 tháng</button>
                        <button type="button" class="btn btn-outline-secondary btn-sm" onclick="addDays(90)">+3 tháng</button>
                        <button type="button" class="btn btn-outline-secondary btn-sm" onclick="addDays(365)">+1 năm</button>
                    </div>
                </div>
                <div id="modalError" class="alert alert-danger d-none"></div>
            </div>
            <div class="modal-footer">
                <button class="btn btn-secondary" data-bs-dismiss="modal">Hủy</button>
                <button class="btn btn-primary" onclick="save()">💾 Lưu</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
const API   = 'http://localhost:5043/api';
const token = '@Context.Session.GetString("AuthToken")';
let allVouchers = [];
const today = new Date().toISOString().split('T')[0];

async function init() {
    const res   = await fetch(`${API}/admin/vouchers`, { headers:{ 'Authorization':'Bearer '+token } });
    allVouchers = await res.json();

    document.getElementById('statTotal').textContent   = allVouchers.length;
    document.getElementById('statActive').textContent  = allVouchers.filter(v => !v.isExpired).length;
    document.getElementById('statExpired').textContent = allVouchers.filter(v =>  v.isExpired).length;

    renderTable();
}

function renderTable() {
    const q      = document.getElementById('searchInput').value.toLowerCase();
    const status = document.getElementById('statusFilter').value;

    const list = allVouchers.filter(v => {
        const matchSearch = v.code.toLowerCase().includes(q);
        const matchStatus = !status ||
            (status === 'active'  && !v.isExpired) ||
            (status === 'expired' &&  v.isExpired);
        return matchSearch && matchStatus;
    });

    if (!list.length) {
        document.getElementById('tableBody').innerHTML =
            '<tr><td colspan="7" class="text-center p-4 text-muted">Không có voucher nào</td></tr>';
        return;
    }

    document.getElementById('tableBody').innerHTML = list.map(v => `
        <tr>
            <td class="text-muted fw-bold small">#${v.id}</td>
            <td>
                <span class="badge text-white fw-bold px-3 py-2"
                      style="background:linear-gradient(135deg,#0d5e58,#0f766e);font-family:monospace;letter-spacing:1px">
                    ${v.code}
                </span>
                <button class="btn btn-sm btn-link p-0 ms-1" onclick="copyCode('${v.code}')" title="Sao chép">📋</button>
            </td>
            <td class="fw-bold" style="color:#b45309">${fmt(v.discountAmount)}</td>
            <td>
                <span class="badge bg-light text-dark border">🔢 ${v.usageLimit} lượt</span>
            </td>
            <td class="${v.isExpired ? 'text-danger' : 'text-success'} fw-semibold small">
                📅 ${v.expiryDate}
            </td>
            <td>
                <span class="badge ${v.isExpired ? 'bg-danger' : 'bg-success'}">
                    ${v.isExpired ? '⏰ Hết hạn' : '✅ Hiệu lực'}
                </span>
            </td>
            <td>
                <button class="btn btn-outline-primary btn-sm me-1" onclick="openEdit(${v.id})">✏️</button>
                <button class="btn btn-outline-danger btn-sm"  onclick="deleteV(${v.id})">🗑️</button>
            </td>
        </tr>
    `).join('');
}

function openCreate() {
    document.getElementById('editId').value    = '';
    document.getElementById('vCode').value     = '';
    document.getElementById('vDiscount').value = '';
    document.getElementById('vLimit').value    = '';
    document.getElementById('vExpiry').value   = '';
    document.getElementById('modalTitle').textContent = '🎟️ Thêm voucher';
    document.getElementById('modalError').classList.add('d-none');
    new bootstrap.Modal(document.getElementById('voucherModal')).show();
}

function openEdit(id) {
    const v = allVouchers.find(x => x.id === id);
    document.getElementById('editId').value    = v.id;
    document.getElementById('vCode').value     = v.code;
    document.getElementById('vDiscount').value = v.discountAmount;
    document.getElementById('vLimit').value    = v.usageLimit;
    document.getElementById('vExpiry').value   = v.expiryDate;
    document.getElementById('modalTitle').textContent = '✏️ Sửa voucher';
    document.getElementById('modalError').classList.add('d-none');
    new bootstrap.Modal(document.getElementById('voucherModal')).show();
}

async function save() {
    const id   = document.getElementById('editId').value;
    const body = {
        code:           document.getElementById('vCode').value.trim().toUpperCase(),
        discountAmount: parseFloat(document.getElementById('vDiscount').value),
        usageLimit:     parseInt(document.getElementById('vLimit').value),
        expiryDate:     document.getElementById('vExpiry').value
    };
    if (!body.code || !body.discountAmount || !body.usageLimit || !body.expiryDate) {
        document.getElementById('modalError').textContent = 'Vui lòng điền đầy đủ!';
        document.getElementById('modalError').classList.remove('d-none');
        return;
    }
    const url    = id ? `${API}/admin/vouchers/${id}` : `${API}/admin/vouchers`;
    const method = id ? 'PUT' : 'POST';
    const res    = await fetch(url, {
        method,
        headers: { 'Authorization':'Bearer '+token, 'Content-Type':'application/json' },
        body: JSON.stringify(body)
    });
    if (!res.ok) {
        const err = await res.json().catch(() => ({}));
        document.getElementById('modalError').textContent = err.message || 'Lỗi!';
        document.getElementById('modalError').classList.remove('d-none');
        return;
    }
    bootstrap.Modal.getInstance(document.getElementById('voucherModal')).hide();
    init();
}

async function deleteV(id) {
    if (!confirm('Xóa voucher này?')) return;
    await fetch(`${API}/admin/vouchers/${id}`, {
        method: 'DELETE', headers: { 'Authorization':'Bearer '+token }
    });
    init();
}

function addDays(days) {
    const d = new Date();
    d.setDate(d.getDate() + days);
    document.getElementById('vExpiry').value = d.toISOString().split('T')[0];
}

function copyCode(code) {
    navigator.clipboard.writeText(code);
    alert(`Đã sao chép: ${code}`);
}

function fmt(n) {
    return new Intl.NumberFormat('vi-VN').format(n || 0) + 'đ';
}

init();
</script>
}