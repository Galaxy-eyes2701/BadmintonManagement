@{
    ViewData["Title"] = "Quản lý Tài khoản";
    ViewData["Page"] = "users";
    Layout = "_AdminLayout";
}

<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Nunito:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
<link rel="stylesheet" href="~/css/account.css" />

<div class="am-wrap">

    <!-- HEADER -->
    <header class="am-header">
        <div class="am-header-left">
            <span class="am-header-icon">👥</span>
            <div>
                <h1 class="am-header-title">Quản lý Tài khoản</h1>
                <p class="am-header-sub">Admin · Nhân viên &amp; Khách hàng</p>
            </div>
        </div>

        <div class="am-header-right">
            <div class="am-stat-chips">
                <div class="am-chip">
                    <span class="am-chip-num" id="hStaff">0</span>
                    <span class="am-chip-label">Nhân viên</span>
                </div>
                <div class="am-chip">
                    <span class="am-chip-num" id="hCustomer">0</span>
                    <span class="am-chip-label">Khách hàng</span>
                </div>
                <div class="am-chip-warn">
                    <span class="am-chip-num" id="hLocked">0</span>
                    <span class="am-chip-label">Bị khóa</span>
                </div>
            </div>

            <button class="am-btn-logout" onclick="handleLogout()">
                <span>🚪</span>
                <span>Đăng xuất</span>
            </button>
        </div>
    </header>

    <!-- ERROR -->
    <div class="am-error" id="errorBanner" style="display:none">
        <span id="errorMsg"></span>
        <button class="am-error-close" onclick="hideError()">✕</button>
    </div>

    <!-- TAB -->
    <div class="am-tabbar">
        <button class="am-tab active" id="tab-staff" onclick="switchTab('staff')">
            🧑‍💼 Nhân viên <span class="am-tab-badge" id="badgeStaff">0</span>
        </button>
        <button class="am-tab" id="tab-customer" onclick="switchTab('customer')">
            🙋 Khách hàng <span class="am-tab-badge" id="badgeCustomer">0</span>
        </button>
    </div>

    <main class="am-content">

        <!-- LOADING -->
        <div class="am-loading" id="loadingWrap">
            <div class="am-spinner"></div>
            <p>Đang tải dữ liệu...</p>
        </div>

        <!-- MAIN -->
        <section id="mainSection" style="display:none">

            <!-- TOOLBAR -->
            <div class="am-toolbar">
                <div class="am-toolbar-left">
                    <div class="am-search-box">
                        <span class="am-search-icon">🔍</span>
                        <input type="text"
                               class="am-search-input"
                               id="searchInput"
                               placeholder="Tìm tên, SĐT, email..."
                               oninput="onSearch(this)" />
                        <button class="am-search-clear" id="searchClear" onclick="clearSearch()">✕</button>
                    </div>

                    <select class="am-filter-select" id="statusFilter" onchange="onStatusFilterChange(this)">
                        <option value="all">Tất cả trạng thái</option>
                        <option value="active">✅ Hoạt động</option>
                        <option value="inactive">🔒 Bị khóa</option>
                    </select>
                </div>

                <button class="am-btn-primary" id="btnAdd" onclick="openCreateStaff()" style="display:none">
                    + Thêm nhân viên
                </button>
            </div>

            <!-- TABLE -->
            <div class="am-table-wrapper">
                <table class="am-table">
                    <thead>
                        <tr id="tableHead"></tr>
                    </thead>
                    <tbody id="tableBody"></tbody>
                </table>

                <div class="am-empty" id="emptyState" style="display:none">
                    <span class="am-empty-icon" id="emptyIcon">🧑‍💼</span>
                    <p id="emptyMsg">Chưa có dữ liệu</p>
                </div>
            </div>

            <!-- PAGINATION -->
            <div class="am-pagination">
                <div style="display:flex;align-items:center;gap:10px">
                    <span id="paginationInfo"></span>
                    <select class="am-per-page-select" onchange="onPerPageChange(this)">
                        <option value="8" selected>8 / trang</option>
                        <option value="15">15 / trang</option>
                        <option value="30">30 / trang</option>
                    </select>
                </div>
                <div class="am-page-btns" id="pageBtns"></div>
            </div>
        </section>
    </main>
</div>

<!-- SAVING OVERLAY -->
<div class="am-saving-overlay" id="savingOverlay">
    <div class="am-saving-box">
        <div class="am-spinner"></div>
        <span>Đang xử lý...</span>
    </div>
</div>

<!-- MODAL STAFF -->
<div class="am-modal-overlay" id="staffModalOverlay" onclick="closeStaffModal(event)">
    <div class="am-modal" onclick="event.stopPropagation()">
        <div class="am-modal-header">
            <div class="am-modal-title-group">
                <span class="am-modal-title-icon">🧑‍💼</span>
                <h3 class="am-modal-title" id="staffModalTitle">Thêm Nhân viên mới</h3>
            </div>
            <button class="am-modal-close" onclick="closeStaffModalDirect()">✕</button>
        </div>

        <div class="am-modal-body">
            <input type="hidden" id="editUserId" />

            <div class="am-form-group">
                <label class="am-label">Họ &amp; Tên <span class="am-required">*</span></label>
                <input type="text" id="staffName" class="am-input" placeholder="VD: Nguyễn Văn A" />
            </div>

            <div class="am-form-row">
                <div class="am-form-group">
                    <label class="am-label">Số điện thoại <span class="am-required">*</span></label>
                    <input type="text" id="staffPhone" class="am-input" placeholder="VD: 0901234567" />
                </div>
                <div class="am-form-group">
                    <label class="am-label">Email</label>
                    <input type="email" id="staffEmail" class="am-input" placeholder="VD: nv@gmail.com" />
                </div>
            </div>

            <div class="am-form-group">
                <label class="am-label">Chi nhánh <span class="am-required">*</span></label>
                <select id="staffBranch" class="am-input">
                    <option value="">-- Chọn chi nhánh --</option>
                </select>
            </div>

            <div class="am-form-group">
                <label class="am-label">
                    Mật khẩu
                    <span class="am-required" id="pwRequired">*</span>
                    <span class="am-label-hint" id="pwHint" style="display:none">(để trống nếu không đổi)</span>
                </label>
                <div class="am-pw-wrap">
                    <input type="password" id="staffPw" class="am-input" placeholder="Nhập mật khẩu mới" autocomplete="new-password" />
                    <button type="button" class="am-eye-btn" onclick="togglePw()" id="eyeBtn">👁️</button>
                </div>
            </div>

            <div class="am-modal-error" id="staffModalError"></div>
        </div>

        <div class="am-modal-footer">
            <button class="am-btn-cancel" onclick="closeStaffModalDirect()">Hủy</button>
            <button class="am-btn-primary" id="staffSaveBtn" onclick="saveStaff()">✅ Tạo nhân viên</button>
        </div>
    </div>
</div>

<!-- MODAL CUSTOMER -->
<div class="am-modal-overlay" id="customerModalOverlay" onclick="closeCustomerModal(event)">
    <div class="am-modal" onclick="event.stopPropagation()">
        <div class="am-modal-header">
            <div class="am-modal-title-group">
                <span class="am-modal-title-icon">🙋</span>
                <h3 class="am-modal-title">Chỉnh sửa Khách hàng</h3>
            </div>
            <button class="am-modal-close" onclick="closeCustomerModalDirect()">✕</button>
        </div>

        <div class="am-modal-body">
            <input type="hidden" id="editCusId" />

            <div class="am-form-group">
                <label class="am-label">Họ &amp; Tên <span class="am-required">*</span></label>
                <input type="text" id="cusName" class="am-input" placeholder="VD: Nguyễn Văn A" />
            </div>

            <div class="am-form-row">
                <div class="am-form-group">
                    <label class="am-label">Số điện thoại <span class="am-required">*</span></label>
                    <input type="text" id="cusPhone" class="am-input" placeholder="VD: 0901234567" />
                </div>
                <div class="am-form-group">
                    <label class="am-label">Email</label>
                    <input type="email" id="cusEmail" class="am-input" placeholder="VD: kh@gmail.com" />
                </div>
            </div>

            <div class="am-form-group">
                <label class="am-label">Điểm tích lũy</label>
                <div class="am-points-wrap">
                    <span class="am-points-prefix">⭐</span>
                    <input type="number" id="cusPoints" class="am-input am-points-input" min="0" placeholder="0" />
                </div>
            </div>

            <div class="am-modal-error" id="cusModalError"></div>
        </div>

        <div class="am-modal-footer">
            <button class="am-btn-cancel" onclick="closeCustomerModalDirect()">Hủy</button>
            <button class="am-btn-primary" id="cusSaveBtn" onclick="saveCustomer()">💾 Lưu thay đổi</button>
        </div>
    </div>
</div>

<!-- MODAL DELETE -->
<div class="am-modal-overlay" id="deleteModalOverlay" onclick="closeDeleteModal(event)">
    <div class="am-modal-sm" onclick="event.stopPropagation()">
        <div class="am-delete-icon">🗑️</div>
        <h3 class="am-delete-title">Xác nhận xóa</h3>
        <p class="am-delete-desc">
            Bạn có chắc muốn xóa tài khoản này không? Hành động này không thể hoàn tác!
        </p>
        <div class="am-modal-footer">
            <button class="am-btn-cancel" id="deleteCancelBtn" onclick="closeDeleteModalDirect()">Hủy</button>
            <button class="am-btn-delete-confirm" id="deleteConfirmBtn" onclick="confirmDelete()">Xóa</button>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        const API   = 'http://localhost:5043/api';
        const TOKEN = '@Context.Session.GetString("AuthToken")';

        const H = {
            'Authorization': 'Bearer ' + TOKEN,
            'Content-Type': 'application/json'
        };

        const H_GET = {
            'Authorization': 'Bearer ' + TOKEN
        };

        let allUsers = [];
        let branches = [];
        let activeTab = 'staff';
        let sortField = 'id';
        let sortDir = 'desc';
        let page = 1;
        let perPage = 8;
        let search = '';
        let filterStatus = 'all';
        let pendingDeleteId = null;
        let showPw = false;

        async function init() {
            showLoading(true);

            try {
                const [uRes, bRes] = await Promise.all([
                    fetch(`${API}/admin/users`, { headers: H_GET }),
                    fetch(`${API}/admin/branches`, { headers: H_GET })
                ]);

                if (!uRes.ok) {
                    throw new Error(`Lỗi tải danh sách: ${uRes.status}`);
                }

                allUsers = await uRes.json();
                branches = bRes.ok ? await bRes.json() : [];

                document.getElementById('staffBranch').innerHTML =
                    '<option value="">-- Chọn chi nhánh --</option>' +
                    branches.map(b => `<option value="${b.id}">${b.name}</option>`).join('');

                updateHeaderChips();
                renderTable();
            } catch (e) {
                showError(e.message);
            } finally {
                showLoading(false);
            }
        }

        function updateHeaderChips() {
            const staffCount = allUsers.filter(u => matchRole(u, 'Staff')).length;
            const customerCount = allUsers.filter(u => matchRole(u, 'Customer')).length;
            const lockedCount = allUsers.filter(u => matchStatus(u, 'inactive')).length;

            document.getElementById('hStaff').textContent = staffCount;
            document.getElementById('hCustomer').textContent = customerCount;
            document.getElementById('hLocked').textContent = lockedCount;
            document.getElementById('badgeStaff').textContent = staffCount;
            document.getElementById('badgeCustomer').textContent = customerCount;
        }

        function matchRole(u, role) {
            return (u.role || '').toLowerCase() === role.toLowerCase();
        }

        function matchStatus(u, status) {
            return (u.status || '').toLowerCase() === status.toLowerCase();
        }

        function getFiltered() {
            const role = activeTab === 'staff' ? 'Staff' : 'Customer';
            const q = search.toLowerCase();

            return allUsers
                .filter(u => {
                    if (!matchRole(u, role)) return false;

                    const fullName = (u.fullName || '').toLowerCase();
                    const phone = (u.phone || '').toLowerCase();
                    const email = (u.email || '').toLowerCase();

                    const matchedSearch =
                        fullName.includes(q) ||
                        phone.includes(q) ||
                        email.includes(q);

                    const matchedStatus =
                        filterStatus === 'all' || matchStatus(u, filterStatus);

                    return matchedSearch && matchedStatus;
                })
                .sort((a, b) => {
                    let vA = a[sortField] ?? '';
                    let vB = b[sortField] ?? '';

                    if (typeof vA === 'string') vA = vA.toLowerCase();
                    if (typeof vB === 'string') vB = vB.toLowerCase();

                    if (vA < vB) return sortDir === 'asc' ? -1 : 1;
                    if (vA > vB) return sortDir === 'asc' ? 1 : -1;
                    return 0;
                });
        }

        function renderTable() {
            const isStaff = activeTab === 'staff';
            const filtered = getFiltered();
            const total = filtered.length;

            const totalPages = Math.max(1, Math.ceil(total / perPage));
            if (page > totalPages) page = totalPages;

            const rows = filtered.slice((page - 1) * perPage, page * perPage);

            function th(field, label) {
                const cls = sortField === field
                    ? (sortDir === 'asc' ? 'am-th-sort sorted-asc' : 'am-th-sort sorted-desc')
                    : 'am-th-sort';

                return `<th class="${cls}" onclick="handleSort('${field}')">${label} <span class="sort-icon"></span></th>`;
            }

            document.getElementById('tableHead').innerHTML =
                th('id', 'ID') +
                th('fullName', 'Họ tên') +
                th('phone', 'SĐT') +
                '<th>Email</th>' +
                (isStaff ? '<th>Chi nhánh</th>' : th('loyaltyPoints', '⭐ Điểm')) +
                th('status', 'Trạng thái') +
                '<th>Thao tác</th>';

            if (!rows.length) {
                document.getElementById('tableBody').innerHTML = '';
                document.getElementById('emptyState').style.display = 'block';
                document.getElementById('emptyIcon').textContent = isStaff ? '🧑‍💼' : '🙋';
                document.getElementById('emptyMsg').textContent = search
                    ? `Không tìm thấy kết quả cho "${search}"`
                    : (isStaff ? 'Chưa có nhân viên nào.' : 'Chưa có khách hàng nào.');
            } else {
                document.getElementById('emptyState').style.display = 'none';

                document.getElementById('tableBody').innerHTML = rows.map((u, i) => {
                    const branchName = isStaff
                        ? (branches.find(b => b.id === u.branchId)?.name || '—')
                        : '';

                    const isActive = matchStatus(u, 'active');
                    const editFunc = isStaff
                        ? `openEditStaff(${u.id})`
                        : `openEditCustomer(${u.id})`;

                    return `
                        <tr style="animation-delay:${i * 0.04}s">
                            <td class="am-td-id">#${u.id}</td>
                            <td>
                                <div class="am-avatar-cell">
                                    <div class="am-avatar ${isActive ? '' : 'locked'}">
                                        ${(u.fullName || '?').charAt(0).toUpperCase()}
                                    </div>
                                    <span class="am-avatar-name">${u.fullName || '---'}</span>
                                </div>
                            </td>
                            <td>${u.phone || '—'}</td>
                            <td class="am-td-email">${u.email || '—'}</td>
                            <td>
                                ${isStaff
                                    ? branchName
                                    : `<span class="am-points-badge">⭐ ${u.loyaltyPoints || 0}</span>`
                                }
                            </td>
                            <td>
                                <button class="am-status-btn ${isActive ? 'am-status-active' : 'am-status-locked'}"
                                        onclick="toggleStatus(${u.id})"
                                        title="${isActive ? 'Nhấn để khóa' : 'Nhấn để mở khóa'}">
                                    ${isActive ? '✅ Hoạt động' : '🔒 Bị khóa'}
                                </button>
                            </td>
                            <td>
                                <div class="am-action-btns">
                                    <button class="am-btn-edit" onclick="${editFunc}">✏️ Sửa</button>
                                    <button class="am-btn-delete" onclick="openDeleteModal(${u.id})">🗑️</button>
                                </div>
                            </td>
                        </tr>
                    `;
                }).join('');
            }

            renderPagination(total);
            document.getElementById('btnAdd').style.display = isStaff ? 'inline-flex' : 'none';
        }

        function renderPagination(total) {
            const totalPages = Math.max(1, Math.ceil(total / perPage));
            if (page > totalPages) page = totalPages;

            const start = total === 0 ? 0 : (page - 1) * perPage + 1;
            const end = Math.min(page * perPage, total);

            document.getElementById('paginationInfo').textContent =
                total ? `Hiển thị ${start}–${end} / ${total}` : 'Không có dữ liệu';

            let btns = `<button class="am-page-btn" onclick="goPage(${page - 1})" ${page <= 1 ? 'disabled' : ''}>‹</button>`;

            for (let p = 1; p <= totalPages; p++) {
                if (totalPages <= 7 || p === 1 || p === totalPages || Math.abs(p - page) <= 1) {
                    btns += `<button class="am-page-btn ${p === page ? 'active' : ''}" onclick="goPage(${p})">${p}</button>`;
                } else if (Math.abs(p - page) === 2) {
                    btns += `<button class="am-page-btn" disabled>…</button>`;
                }
            }

            btns += `<button class="am-page-btn" onclick="goPage(${page + 1})" ${page >= totalPages ? 'disabled' : ''}>›</button>`;

            document.getElementById('pageBtns').innerHTML = btns;
        }

        function goPage(p) {
            const total = getFiltered().length;
            const totalPages = Math.max(1, Math.ceil(total / perPage));
            if (p < 1 || p > totalPages) return;
            page = p;
            renderTable();
        }

        function onPerPageChange(select) {
            perPage = parseInt(select.value);
            page = 1;
            renderTable();
        }

        function handleSort(field) {
            if (sortField === field) {
                sortDir = sortDir === 'asc' ? 'desc' : 'asc';
            } else {
                sortField = field;
                sortDir = 'asc';
            }

            page = 1;
            renderTable();
        }

        function switchTab(tab) {
            activeTab = tab;
            search = '';
            filterStatus = 'all';
            page = 1;
            sortField = 'id';
            sortDir = 'desc';

            document.getElementById('searchInput').value = '';
            document.getElementById('statusFilter').value = 'all';
            document.getElementById('searchClear').style.display = 'none';

            document.getElementById('tab-staff').classList.toggle('active', tab === 'staff');
            document.getElementById('tab-customer').classList.toggle('active', tab === 'customer');

            renderTable();
        }

        function onSearch(input) {
            search = input.value.trim();
            document.getElementById('searchClear').style.display = search ? 'block' : 'none';
            page = 1;
            renderTable();
        }

        function clearSearch() {
            search = '';
            document.getElementById('searchInput').value = '';
            document.getElementById('searchClear').style.display = 'none';
            page = 1;
            renderTable();
        }

        function onStatusFilterChange(select) {
            filterStatus = select.value;
            page = 1;
            renderTable();
        }

        function openCreateStaff() {
            document.getElementById('editUserId').value = '';
            document.getElementById('staffName').value = '';
            document.getElementById('staffPhone').value = '';
            document.getElementById('staffEmail').value = '';
            document.getElementById('staffPw').value = '';
            document.getElementById('staffBranch').value = '';
            document.getElementById('staffModalTitle').textContent = 'Thêm Nhân viên mới';
            document.getElementById('staffSaveBtn').textContent = '✅ Tạo nhân viên';
            document.getElementById('pwRequired').style.display = 'inline';
            document.getElementById('pwHint').style.display = 'none';
            document.getElementById('staffPw').placeholder = 'Nhập mật khẩu mới';
            hideStaffError();
            showModal('staffModalOverlay');
        }

        function openEditStaff(id) {
            const u = allUsers.find(x => x.id === id);
            if (!u) return;

            document.getElementById('editUserId').value = u.id;
            document.getElementById('staffName').value = u.fullName || '';
            document.getElementById('staffPhone').value = u.phone || '';
            document.getElementById('staffEmail').value = u.email || '';
            document.getElementById('staffBranch').value = u.branchId || '';
            document.getElementById('staffPw').value = '';
            document.getElementById('staffModalTitle').textContent = 'Chỉnh sửa Nhân viên';
            document.getElementById('staffSaveBtn').textContent = '💾 Lưu thay đổi';
            document.getElementById('pwRequired').style.display = 'none';
            document.getElementById('pwHint').style.display = 'inline';
            document.getElementById('staffPw').placeholder = 'Để trống nếu không đổi';
            hideStaffError();
            showModal('staffModalOverlay');
        }

        async function saveStaff() {
            const id = document.getElementById('editUserId').value;
            const name = document.getElementById('staffName').value.trim();
            const phone = document.getElementById('staffPhone').value.trim();
            const email = document.getElementById('staffEmail').value.trim();
            const branchId = document.getElementById('staffBranch').value;
            const pw = document.getElementById('staffPw').value;

            if (!name || !phone || !branchId || (!id && !pw)) {
                showStaffError('Vui lòng điền đầy đủ các trường bắt buộc!');
                return;
            }

            setSaving(true);

            const body = {
                fullName: name,
                phone: phone,
                email: email,
                password: pw,
                branchId: parseInt(branchId)
            };

            try {
                const res = await fetch(id ? `${API}/admin/users/${id}` : `${API}/admin/users`, {
                    method: id ? 'PUT' : 'POST',
                    headers: H,
                    body: JSON.stringify(body)
                });

                if (!res.ok) {
                    const e = await res.json().catch(() => ({}));
                    throw new Error(e.message || `Thao tác thất bại (${res.status})`);
                }

                closeStaffModalDirect();
                await reload();
            } catch (e) {
                showStaffError(e.message);
            } finally {
                setSaving(false);
            }
        }

        function openEditCustomer(id) {
            const u = allUsers.find(x => x.id === id);
            if (!u) return;

            document.getElementById('editCusId').value = u.id;
            document.getElementById('cusName').value = u.fullName || '';
            document.getElementById('cusPhone').value = u.phone || '';
            document.getElementById('cusEmail').value = u.email || '';
            document.getElementById('cusPoints').value = u.loyaltyPoints || 0;
            hideCusError();
            showModal('customerModalOverlay');
        }

        async function saveCustomer() {
            const id = document.getElementById('editCusId').value;
            const name = document.getElementById('cusName').value.trim();
            const phone = document.getElementById('cusPhone').value.trim();
            const email = document.getElementById('cusEmail').value.trim();
            const points = Math.max(0, parseInt(document.getElementById('cusPoints').value) || 0);

            if (!name || !phone) {
                showCusError('Vui lòng nhập họ tên và số điện thoại!');
                return;
            }

            setSaving(true);

            const body = {
                fullName: name,
                phone: phone,
                email: email,
                loyaltyPoints: points
            };

            try {
                const res = await fetch(`${API}/admin/users/${id}/customer`, {
                    method: 'PUT',
                    headers: H,
                    body: JSON.stringify(body)
                });

                if (!res.ok) {
                    const e = await res.json().catch(() => ({}));
                    throw new Error(e.message || `Cập nhật thất bại (${res.status})`);
                }

                closeCustomerModalDirect();
                await reload();
            } catch (e) {
                showCusError(e.message);
            } finally {
                setSaving(false);
            }
        }

        async function toggleStatus(id) {
            setSaving(true);

            try {
                const res = await fetch(`${API}/admin/users/${id}/toggle-status`, {
                    method: 'PATCH',
                    headers: H_GET
                });

                if (!res.ok) {
                    throw new Error(`Đổi trạng thái thất bại: ${res.status}`);
                }

                await reload();
            } catch (e) {
                showError(e.message);
            } finally {
                setSaving(false);
            }
        }

        function openDeleteModal(id) {
            pendingDeleteId = id;
            showModal('deleteModalOverlay');
        }

        async function confirmDelete() {
            if (!pendingDeleteId) return;

            setSaving(true);

            const btn = document.getElementById('deleteConfirmBtn');
            const btnCancel = document.getElementById('deleteCancelBtn');

            btn.textContent = '⏳ Đang xóa...';
            btn.disabled = true;
            btnCancel.disabled = true;

            try {
                const res = await fetch(`${API}/admin/users/${pendingDeleteId}`, {
                    method: 'DELETE',
                    headers: H_GET
                });

                if (!res.ok) {
                    throw new Error(`Xóa thất bại: ${res.status}`);
                }

                closeDeleteModalDirect();
                await reload();
            } catch (e) {
                showError(e.message);
                closeDeleteModalDirect();
            } finally {
                setSaving(false);
                btn.textContent = 'Xóa';
                btn.disabled = false;
                btnCancel.disabled = false;
            }
        }

        async function reload() {
            const r = await fetch(`${API}/admin/users`, { headers: H_GET });

            if (r.ok) {
                allUsers = await r.json();
                updateHeaderChips();
                renderTable();
            }
        }

        function showModal(id) {
            document.getElementById(id).classList.add('visible');
        }

        function hideModal(id) {
            document.getElementById(id).classList.remove('visible');
        }

        function closeStaffModal(e) {
            if (e.target.id === 'staffModalOverlay') closeStaffModalDirect();
        }

        function closeStaffModalDirect() {
            hideModal('staffModalOverlay');
            hideStaffError();
        }

        function closeCustomerModal(e) {
            if (e.target.id === 'customerModalOverlay') closeCustomerModalDirect();
        }

        function closeCustomerModalDirect() {
            hideModal('customerModalOverlay');
            hideCusError();
        }

        function closeDeleteModal(e) {
            if (e.target.id === 'deleteModalOverlay') closeDeleteModalDirect();
        }

        function closeDeleteModalDirect() {
            hideModal('deleteModalOverlay');
            pendingDeleteId = null;
        }

        function togglePw() {
            showPw = !showPw;
            document.getElementById('staffPw').type = showPw ? 'text' : 'password';
            document.getElementById('eyeBtn').textContent = showPw ? '🙈' : '👁️';
        }

        function showError(message) {
            document.getElementById('errorMsg').textContent = '⚠️ ' + message;
            document.getElementById('errorBanner').style.display = 'flex';
        }

        function hideError() {
            document.getElementById('errorBanner').style.display = 'none';
        }

        function showStaffError(message) {
            const el = document.getElementById('staffModalError');
            el.textContent = message;
            el.style.display = 'block';
        }

        function hideStaffError() {
            document.getElementById('staffModalError').style.display = 'none';
        }

        function showCusError(message) {
            const el = document.getElementById('cusModalError');
            el.textContent = message;
            el.style.display = 'block';
        }

        function hideCusError() {
            document.getElementById('cusModalError').style.display = 'none';
        }

        function setSaving(on) {
            document.getElementById('savingOverlay').classList.toggle('visible', on);
        }

        function showLoading(on) {
            document.getElementById('loadingWrap').style.display = on ? 'flex' : 'none';
            document.getElementById('mainSection').style.display = on ? 'none' : 'block';
        }

        function handleLogout() {
            if (confirm('Bạn có chắc chắn muốn đăng xuất?')) {
                window.location.href = '/admin/login';
            }
        }

        init();
    </script>
}