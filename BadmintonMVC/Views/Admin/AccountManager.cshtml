@section Scripts {
    <script>
        // ══════════════════════════════════════════════════════
        //  CONFIG
        // ══════════════════════════════════════════════════════
        const API   = 'http://localhost:5043/api';
        const TOKEN = '@Context.Session.GetString("AuthToken")';
        const H     = { 'Authorization':'Bearer '+TOKEN, 'Content-Type':'application/json' };
        const H_GET = { 'Authorization':'Bearer '+TOKEN };

        // ── State ──
        let allUsers   = [];
        let branches   = [];
        let activeTab  = 'staff';
        let sortField  = 'id';
        let sortDir    = 'desc';
        let page       = 1;
        let perPage    = 8;
        let search     = '';
        let filterStatus = 'all';
        let pendingDeleteId = null;
        let showPw     = false;

        // ══════════════════════════════════════════════════════
        //  INIT
        // ══════════════════════════════════════════════════════
        async function init() {
            showLoading(true);
            try {
                const [uRes, bRes] = await Promise.all([
                    fetch(`${API}/admin/users`,    {headers:H_GET}),
                    fetch(`${API}/admin/branches`, {headers:H_GET})
                ]);
                if (!uRes.ok) throw new Error(`Lỗi tải danh sách: ${uRes.status}`);
                allUsers = await uRes.json();
                branches = bRes.ok ? await bRes.json() : [];
                // populate branch select
                const sel = document.getElementById('staffBranch');
                sel.innerHTML = '<option value="">-- Chọn chi nhánh --</option>' +
                    branches.map(b=>`<option value="${b.id}">${b.name}</option>`).join('');
                updateHeaderChips();
                renderTable();
            } catch(e) { showError(e.message); }
            finally    { showLoading(false); }
        }

        // ══════════════════════════════════════════════════════
        //  HEADER CHIPS
        // ══════════════════════════════════════════════════════
        function updateHeaderChips() {
            const staff    = allUsers.filter(u=>matchRole(u,'Staff')).length;
            const customer = allUsers.filter(u=>matchRole(u,'Customer')).length;
            const locked   = allUsers.filter(u=>matchStatus(u,'inactive')).length;
            document.getElementById('hStaff').textContent    = staff;
            document.getElementById('hCustomer').textContent = customer;
            document.getElementById('hLocked').textContent   = locked;
            document.getElementById('badgeStaff').textContent    = staff;
            document.getElementById('badgeCustomer').textContent = customer;
        }

        // ══════════════════════════════════════════════════════
        //  FILTER + SORT + PAGINATE
        // ══════════════════════════════════════════════════════
        function matchRole(u,role){ return (u.role||'').toLowerCase()===role.toLowerCase(); }
        function matchStatus(u,st){ return (u.status||'').toLowerCase()===st.toLowerCase(); }

        function getFiltered() {
            const role = activeTab==='staff' ? 'Staff' : 'Customer';
            const q    = search.toLowerCase();
            let list   = allUsers.filter(u => {
                if(!matchRole(u,role)) return false;
                const matchS = u.fullName.toLowerCase().includes(q) ||
                               u.phone.includes(q) || (u.email||'').toLowerCase().includes(q);
                const matchF = filterStatus==='all' || matchStatus(u,filterStatus);
                return matchS && matchF;
            });
            list.sort((a,b)=>{
                let vA = a[sortField]??'', vB = b[sortField]??'';
                if(typeof vA==='string') vA=vA.toLowerCase();
                if(typeof vB==='string') vB=vB.toLowerCase();
                return vA<vB ? (sortDir==='asc'?-1:1) : vA>vB ? (sortDir==='asc'?1:-1) : 0;
            });
            return list;
        }

        // ══════════════════════════════════════════════════════
        //  RENDER TABLE
        // ══════════════════════════════════════════════════════
        function renderTable() {
            const isStaff = activeTab==='staff';
            const filtered = getFiltered();
            const total    = filtered.length;
            const start    = (page-1)*perPage;
            const rows     = filtered.slice(start, start+perPage);

            // Header
            function thSort(field, label) {
                const cls = sortField===field ? (sortDir==='asc'?'am-th-sort sorted-asc':'am-th-sort sorted-desc') : 'am-th-sort';
                return `<th class="${cls}" onclick="handleSort('${field}')">${label} <span class="sort-icon"></span></th>`;
            }
            document.getElementById('tableHead').innerHTML =
                thSort('id','ID') +
                thSort('fullName','Họ tên') +
                thSort('phone','SĐT') +
                '<th>Email</th>' +
                (isStaff ? '<th>Chi nhánh</th>' : thSort('loyaltyPoints','⭐ Điểm')) +
                thSort('status','Trạng thái') +
                '<th>Thao tác</th>';

            // Body
            if(!rows.length) {
                document.getElementById('tableBody').innerHTML = '';
                document.getElementById('emptyState').style.display = 'block';
                document.getElementById('emptyIcon').textContent = isStaff ? '🧑‍💼' : '🙋';
                document.getElementById('emptyMsg').textContent  = search
                    ? `Không tìm thấy kết quả cho "${search}"`
                    : isStaff ? 'Chưa có nhân viên nào.' : 'Chưa có khách hàng nào.';
            } else {
                document.getElementById('emptyState').style.display = 'none';
                document.getElementById('tableBody').innerHTML = rows.map((u,i) => {
                    const branchName = isStaff ? (branches.find(b=>b.id===u.branchId)?.name||'—') : '';
                    const isActive   = matchStatus(u,'active');
                    const avatarCls  = isActive ? '' : 'locked';
                    const statusCls  = isActive ? 'am-status-active' : 'am-status-locked';
                    const statusTxt  = isActive ? '✅ Hoạt động' : '🔒 Bị khóa';
                    const editFn     = isStaff ? `openEditStaff(${u.id})` : `openEditCustomer(${u.id})`;
                    return `
                    <tr style="animation-delay:${i*0.04}s">
                        <td class="am-td-id">#${u.id}</td>
                        <td>
                            <div class="am-avatar-cell">
                                <div class="am-avatar ${avatarCls}">${(u.fullName||'?').charAt(0).toUpperCase()}</div>
                                <span class="am-avatar-name">${u.fullName}</span>
                            </div>
                        </td>
                        <td>${u.phone}</td>
                        <td class="am-td-email">${u.email||'—'}</td>
                        <td>${isStaff
                            ? branchName
                            : `<span class="am-points-badge">⭐ ${u.loyaltyPoints||0}</span>`
                        }</td>
                        <td>
                            <button class="am-status-btn ${statusCls}" onclick="toggleStatus(${u.id})"
                                    title="${isActive?'Nhấn để khóa':'Nhấn để mở khóa'}">
                                ${statusTxt}
                            </button>
                        </td>
                        <td>
                            <div class="am-action-btns">
                                <button class="am-btn-edit"   onclick="${editFn}">✏️ Sửa</button>
                                <button class="am-btn-delete" onclick="openDeleteModal(${u.id})">🗑️</button>
                            </div>
                        </td>
                    </tr>`;
                }).join('');
            }

            // Pagination
            renderPagination(total);
            document.getElementById('btnAdd').style.display = isStaff ? '' : 'none';
        }

        // ══════════════════════════════════════════════════════
        //  PAGINATION
        // ══════════════════════════════════════════════════════
        function renderPagination(total) {
            const totalPages = Math.max(1, Math.ceil(total/perPage));
            if(page > totalPages) page = totalPages;
            const start = (page-1)*perPage + 1;
            const end   = Math.min(page*perPage, total);
            document.getElementById('paginationInfo').textContent =
                total ? `Hiển thị ${start}–${end} / ${total}` : 'Không có dữ liệu';

            let btns = '';
            btns += `<button class="am-page-btn" onclick="goPage(${page-1})" ${page<=1?'disabled':''}>‹</button>`;
            for(let p=1;p<=totalPages;p++){
                if(totalPages<=7 || p===1 || p===totalPages || Math.abs(p-page)<=1){
                    btns += `<button class="am-page-btn ${p===page?'active':''}" onclick="goPage(${p})">${p}</button>`;
                } else if(Math.abs(p-page)===2){
                    btns += `<button class="am-page-btn" disabled>…</button>`;
                }
            }
            btns += `<button class="am-page-btn" onclick="goPage(${page+1})" ${page>=totalPages?'disabled':''}>›</button>`;
            document.getElementById('pageBtns').innerHTML = btns;
        }

        function goPage(p)    { page = p; renderTable(); }
        function onPerPageChange(sel){ perPage=parseInt(sel.value); page=1; renderTable(); }

        // ══════════════════════════════════════════════════════
        //  SORT
        // ══════════════════════════════════════════════════════
        function handleSort(field){
            if(sortField===field) sortDir = sortDir==='asc'?'desc':'asc';
            else { sortField=field; sortDir='asc'; }
            page=1; renderTable();
        }

        // ══════════════════════════════════════════════════════
        //  TAB SWITCH
        // ══════════════════════════════════════════════════════
        function switchTab(tab){
            activeTab = tab; search=''; filterStatus='all'; page=1; sortField='id'; sortDir='desc';
            document.getElementById('searchInput').value  = '';
            document.getElementById('statusFilter').value = 'all';
            document.getElementById('searchClear').style.display = 'none';
            document.getElementById('tab-staff').classList.toggle('active',   tab==='staff');
            document.getElementById('tab-customer').classList.toggle('active', tab==='customer');
            renderTable();
        }

        // ══════════════════════════════════════════════════════
        //  SEARCH
        // ══════════════════════════════════════════════════════
        function onSearch(inp){
            search = inp.value;
            document.getElementById('searchClear').style.display = search ? 'block':'none';
            page=1; renderTable();
        }
        function clearSearch(){
            search=''; document.getElementById('searchInput').value='';
            document.getElementById('searchClear').style.display='none';
            page=1; renderTable();
        }

        // ══════════════════════════════════════════════════════
        //  STAFF CRUD
        // ══════════════════════════════════════════════════════
        function openCreateStaff(){
            document.getElementById('editUserId').value  = '';
            document.getElementById('staffName').value   = '';
            document.getElementById('staffPhone').value  = '';
            document.getElementById('staffEmail').value  = '';
            document.getElementById('staffPw').value     = '';
            document.getElementById('staffBranch').value = '';
            document.getElementById('staffModalTitle').textContent = 'Thêm Nhân viên mới';
            document.getElementById('staffSaveBtn').textContent    = '✅ Tạo nhân viên';
            document.getElementById('pwRequired').style.display    = 'inline';
            document.getElementById('pwHint').style.display        = 'none';
            document.getElementById('staffPw').placeholder         = 'Nhập mật khẩu mới';
            hideStaffError();
            showModal('staffModalOverlay');
        }

        function openEditStaff(id){
            const u = allUsers.find(x=>x.id===id);
            document.getElementById('editUserId').value  = u.id;
            document.getElementById('staffName').value   = u.fullName;
            document.getElementById('staffPhone').value  = u.phone;
            document.getElementById('staffEmail').value  = u.email||'';
            document.getElementById('staffBranch').value = u.branchId||'';
            document.getElementById('staffPw').value     = '';
            document.getElementById('staffModalTitle').textContent = 'Chỉnh sửa Nhân viên';
            document.getElementById('staffSaveBtn').textContent    = '💾 Lưu thay đổi';
            document.getElementById('pwRequired').style.display    = 'none';
            document.getElementById('pwHint').style.display        = 'inline';
            document.getElementById('staffPw').placeholder         = 'Để trống nếu không đổi';
            hideStaffError();
            showModal('staffModalOverlay');
        }

        async function saveStaff(){
            const id       = document.getElementById('editUserId').value;
            const name     = document.getElementById('staffName').value.trim();
            const phone    = document.getElementById('staffPhone').value.trim();
            const branchId = document.getElementById('staffBranch').value;
            const pw       = document.getElementById('staffPw').value;
            if(!name||!phone||!branchId||(!id&&!pw)){ showStaffError('Vui lòng điền đầy đủ các trường bắt buộc!'); return; }

            setSaving(true);
            const body = { fullName:name, phone, email:document.getElementById('staffEmail').value, password:pw, branchId:parseInt(branchId) };
            const url  = id ? `${API}/admin/users/${id}` : `${API}/admin/users`;
            const method = id ? 'PUT' : 'POST';
            try {
                const res = await fetch(url, {method, headers:H, body:JSON.stringify(body)});
                if(!res.ok){ const e=await res.json().catch(()=>({})); throw new Error(e.message||`Thao tác thất bại (${res.status})`); }
                closeStaffModalDirect(); await reload();
            } catch(e){ showStaffError(e.message); }
            finally   { setSaving(false); }
        }

        // ══════════════════════════════════════════════════════
        //  CUSTOMER CRUD
        // ══════════════════════════════════════════════════════
        function openEditCustomer(id){
            const u = allUsers.find(x=>x.id===id);
            document.getElementById('editCusId').value  = u.id;
            document.getElementById('cusName').value    = u.fullName;
            document.getElementById('cusPhone').value   = u.phone;
            document.getElementById('cusEmail').value   = u.email||'';
            document.getElementById('cusPoints').value  = u.loyaltyPoints||0;
            hideCusError();
            showModal('customerModalOverlay');
        }

        async function saveCustomer(){
            const id    = document.getElementById('editCusId').value;
            const name  = document.getElementById('cusName').value.trim();
            const phone = document.getElementById('cusPhone').value.trim();
            if(!name||!phone){ hideCusError(); showCusError('Vui lòng nhập họ tên và số điện thoại!'); return; }

            setSaving(true);
            const body = { fullName:name, phone, email:document.getElementById('cusEmail').value, loyaltyPoints:Math.max(0,parseInt(document.getElementById('cusPoints').value)||0) };
            try {
                const res = await fetch(`${API}/admin/users/${id}/customer`, {method:'PUT', headers:H, body:JSON.stringify(body)});
                if(!res.ok){ const e=await res.json().catch(()=>({})); throw new Error(e.message||`Cập nhật thất bại (${res.status})`); }
                closeCustomerModalDirect(); await reload();
            } catch(e){ showCusError(e.message); }
            finally   { setSaving(false); }
        }

        // ══════════════════════════════════════════════════════
        //  SHARED ACTIONS
        // ══════════════════════════════════════════════════════
        async function toggleStatus(id){
            setSaving(true);
            try {
                const res = await fetch(`${API}/admin/users/${id}/toggle-status`,{method:'PATCH',headers:H_GET});
                if(!res.ok) throw new Error(`Đổi trạng thái thất bại: ${res.status}`);
                await reload();
            } catch(e){ showError(e.message); }
            finally   { setSaving(false); }
        }

        function openDeleteModal(id){ pendingDeleteId=id; showModal('deleteModalOverlay'); }

        async function confirmDelete(){
            if(!pendingDeleteId) return;
            setSaving(true);
            document.getElementById('deleteConfirmBtn').textContent = '⏳ Đang xóa...';
            document.getElementById('deleteConfirmBtn').disabled = true;
            document.getElementById('deleteCancelBtn').disabled  = true;
            try {
                const res = await fetch(`${API}/admin/users/${pendingDeleteId}`,{method:'DELETE',headers:H_GET});
                if(!res.ok) throw new Error(`Xóa thất bại: ${res.status}`);
                closeDeleteModalDirect(); await reload();
            } catch(e){ showError(e.message); closeDeleteModalDirect(); }
            finally   { setSaving(false); document.getElementById('deleteConfirmBtn').textContent='Xóa'; document.getElementById('deleteConfirmBtn').disabled=false; document.getElementById('deleteCancelBtn').disabled=false; }
        }

        async function reload(){
            const uRes = await fetch(`${API}/admin/users`,{headers:H_GET});
            if(uRes.ok){ allUsers = await uRes.json(); updateHeaderChips(); renderTable(); }
        }

        // ══════════════════════════════════════════════════════
        //  MODAL HELPERS
        // ══════════════════════════════════════════════════════
        function showModal(id)    { document.getElementById(id).classList.add('visible'); }
        function hideModal(id)    { document.getElementById(id).classList.remove('visible'); }

        function closeStaffModal(e) { if(e.target.id==='staffModalOverlay') closeStaffModalDirect(); }
        function closeStaffModalDirect()    { hideModal('staffModalOverlay'); hideStaffError(); }
        function closeCustomerModal(e)      { if(e.target.id==='customerModalOverlay') closeCustomerModalDirect(); }
        function closeCustomerModalDirect() { hideModal('customerModalOverlay'); hideCusError(); }
        function closeDeleteModal(e)        { if(e.target.id==='deleteModalOverlay') closeDeleteModalDirect(); }
        function closeDeleteModalDirect()   { hideModal('deleteModalOverlay'); pendingDeleteId=null; }

        // ── Password toggle ──
        function togglePw(){
            showPw = !showPw;
            const inp = document.getElementById('staffPw');
            inp.type = showPw ? 'text' : 'password';
            document.getElementById('eyeBtn').textContent = showPw ? '🙈' : '👁️';
        }

        // ── Error/saving helpers ──
        function showError(msg){ document.getElementById('errorMsg').textContent='⚠️ '+msg; document.getElementById('errorBanner').style.display='flex'; }
        function hideError()   { document.getElementById('errorBanner').style.display='none'; }
        function showStaffError(msg){ const el=document.getElementById('staffModalError'); el.textContent=msg; el.style.display='block'; }
        function hideStaffError()   { document.getElementById('staffModalError').style.display='none'; }
        function showCusError(msg)  { const el=document.getElementById('cusModalError'); el.textContent=msg; el.style.display='block'; }
        function hideCusError()     { document.getElementById('cusModalError').style.display='none'; }
        function setSaving(on)      { document.getElementById('savingOverlay').classList.toggle('visible',on); }
        function showLoading(on)    { document.getElementById('loadingWrap').style.display=on?'flex':'none'; document.getElementById('mainSection').style.display=on?'none':'block'; }

        function handleLogout(){
            if(confirm('Bạn có chắc chắn muốn đăng xuất?')){
                window.location.href='/admin/login';
            }
        }

        // ══════════════════════════════════════════════════════
        //  KICK OFF
        // ══════════════════════════════════════════════════════
        init();
    </script>
}
