@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <title>Admin Login</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Nunito:wght@400;600;700;800;900&display=swap"
          rel="stylesheet" />
    <style>
            body {
                font-family: 'Nunito', sans-serif;
                background: linear-gradient(135deg, #0d5e58, #0f766e, #14b8a6);
                min-height: 100vh;
                display: flex;
                align-items: center;
                justify-content: center;
            }

            .card {
                border-radius: 16px;
                border: none;
                box-shadow: 0 20px 60px rgba(0, 0, 0, .25);
                animation: slideUp .3s ease;
            }

            @@keyframes slideUp {
                from {
                    opacity: 0;
                    transform: translateY(20px);
                }

                to {
                    opacity: 1;
                    transform: translateY(0);
                }
            }

            .btn-primary {
                background: linear-gradient(135deg, #0f766e, #14b8a6);
                border: none;
                font-weight: 700;
                padding: 12px;
            }

            .btn-primary:hover {
                background: linear-gradient(135deg, #0d5e58, #0f766e);
            }

            .form-control:focus {
                border-color: #14b8a6;
                box-shadow: 0 0 0 3px rgba(20, 184, 166, .15);
            }

            .logo-wrap {
                width: 72px;
                height: 72px;
                background: linear-gradient(135deg, #0f766e, #14b8a6);
                border-radius: 20px;
                display: flex;
                align-items: center;
                justify-content: center;
                margin: 0 auto 16px;
                box-shadow: 0 8px 24px rgba(15, 118, 110, .35);
                font-size: 36px;
            }
    </style>
</head>

<body>
    <div class="card p-4" style="width:420px">
        <div class="text-center mb-4">
            <div class="logo-wrap">🏸</div>
            <h4 class="fw-black mb-0" style="color:#0f766e">Đăng nhập Admin</h4>
            <p class="text-muted small mt-1">Hệ thống quản lý sân cầu lông</p>
        </div>

        @if (ViewBag.Error != null)
        {
            <div class="alert alert-danger py-2 small fw-semibold">
                ⚠️ @ViewBag.Error
            </div>
        }

        <form method="post" action="/admin/login">
            <div class="mb-3">
                <label class="form-label fw-semibold">Tên đăng nhập</label>
                <input type="text" name="username" class="form-control" placeholder="admin" required autofocus />
            </div>
            <div class="mb-4">
                <label class="form-label fw-semibold">Mật khẩu</label>
                <input type="password" name="password" class="form-control" placeholder="••••••••" required />
            </div>
            <button type="submit" class="btn btn-primary w-100">
                Đăng nhập
            </button>
        </form>

        <div class="mt-3 p-3 rounded text-center" style="background:#f0fdf9;border:1px solid #a7f3d0">
            <small class="text-muted">
                Tài khoản mặc định: <strong>admin</strong> / <strong>admin</strong>
            </small>
        </div>
    </div>
</body>

</html>