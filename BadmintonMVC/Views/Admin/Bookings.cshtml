@{
    ViewData["Title"] = "Quản lý Booking";
    ViewData["Page"] = "bookings";
    Layout = "_AdminLayout";
}

<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Nunito:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
<link rel="stylesheet" href="~/css/bookings.css" />

<div class="bk-wrap">

    <!-- ══ HEADER ══ -->
    <header class="bk-header">
        <div class="bk-header-left">
            <span class="bk-header-icon">🏸</span>
            <div>
                <h1 class="bk-header-title">Quản lý Booking</h1>
                <p class="bk-header-sub">Admin · Duyệt &amp; hủy lịch đặt sân</p>
            </div>
        </div>
        <div class="bk-header-right">
            <div class="bk-stat-chips">
                <div class="bk-chip">
                    <span class="bk-chip-num" id="hTotal">0</span>
                    <span class="bk-chip-label">Tổng</span>
                </div>
                <div class="bk-chip-warn">
                    <span class="bk-chip-num" id="hPending">0</span>
                    <span class="bk-chip-label">Chờ duyệt</span>
                </div>
                <div class="bk-chip-success">
                    <span class="bk-chip-num" id="hConfirmed">0</span>
                    <span class="bk-chip-label">Đã xác nhận</span>
                </div>
                <div class="bk-chip-danger">
                    <span class="bk-chip-num" id="hCancelled">0</span>
                    <span class="bk-chip-label">Đã hủy</span>
                </div>
            </div>
            <button class="bk-btn-logout" onclick="handleLogout()">
                <span>🚪</span><span>Đăng xuất</span>
            </button>
        </div>
    </header>

    <!-- ══ BANNERS ══ -->
    <div class="bk-banner bk-banner-error" id="errorBanner" style="display:none">
        <span id="errorMsg"></span>
        <button class="bk-banner-close" onclick="hideError()">✕</button>
    </div>
    <div class="bk-banner bk-banner-success" id="successBanner" style="display:none">
        <span id="successMsg"></span>
        <button class="bk-banner-close" onclick="document.getElementById('successBanner').style.display='none'">✕</button>
    </div>

    <main class="bk-content">

        <!-- TOOLBAR -->
        <div class="bk-toolbar">
            <div class="bk-toolbar-left">
                <div class="bk-search-box">
                    <span class="bk-search-icon">🔍</span>
                    <input type="text" class="bk-search-input" id="searchInput"
                           placeholder="Tìm tên hoặc SĐT khách..." oninput="onSearch(this)" />
                    <button class="bk-search-clear" id="searchClear" onclick="clearSearch()">✕</button>
                </div>
                <select class="bk-filter-select" id="statusFilter" onchange="onFilterChange()">
                    <option value="">🗂️ Tất cả</option>
                    <option value="pending">⏳ Chờ xác nhận</option>
                    <option value="confirmed">✅ Đã xác nhận</option>
                    <option value="cancelled">🚫 Đã hủy</option>
                </select>
                <div class="bk-date-range">
                    <input type="date" class="bk-filter-select" id="fromDate" onchange="onFilterChange()" />
                    <span class="bk-date-sep">→</span>
                    <input type="date" class="bk-filter-select" id="toDate" onchange="onFilterChange()" />
                </div>
            </div>
            <button class="bk-btn-primary" onclick="fetchData()">🔄 Làm mới</button>
        </div>

        <!-- LOADING -->
        <div class="bk-loading" id="loadingWrap">
            <div class="bk-spinner"></div>
            <p>Đang tải danh sách booking...</p>
        </div>

        <!-- TABLE -->
        <div id="tableSection" style="display:none">
            <div class="bk-table-wrap">
                <table class="bk-table">
                    <thead>
                        <tr>
                            <th>#ID</th>
                            <th>Khách hàng</th>
                            <th>SĐT</th>
                            <th>Ngày tạo</th>
                            <th>Số sân</th>
                            <th>Tổng tiền</th>
                            <th>Trạng thái</th>
                            <th>Thao tác</th>
                        </tr>
                    </thead>
                    <tbody id="tableBody"></tbody>
                </table>
            </div>
            <div class="bk-pagination">
                <div style="display:flex;align-items:center;gap:10px">
                    <span id="pageInfo"></span>
                    <select class="bk-per-page-select" onchange="onPerPageChange(this)">
                        <option value="10" selected>10 / trang</option>
                        <option value="20">20 / trang</option>
                        <option value="50">50 / trang</option>
                    </select>
                </div>
                <div class="bk-page-btns" id="pageBtns"></div>
            </div>
        </div>

    </main>
</div>

<!-- ══ SAVING OVERLAY ══ -->
<div class="bk-saving-overlay" id="savingOverlay">
    <div class="bk-saving-box"><div class="bk-spinner"></div><span>Đang xử lý...</span></div>
</div>

<!-- ══ MODAL: CHI TIẾT ══ -->
<div class="bk-modal-overlay" id="detailModalOverlay" onclick="closeDetailModal(event)">
    <div class="bk-modal-lg" onclick="event.stopPropagation()">
        <div class="bk-modal-header">
            <div class="bk-modal-title-group">
                <span class="bk-modal-title-icon">🏸</span>
                <h3 class="bk-modal-title" id="detailTitle">Chi tiết Booking</h3>
            </div>
            <button class="bk-modal-close" onclick="closeDetailModalDirect()">✕</button>
        </div>
        <div class="bk-modal-body" id="detailBody">
            <div class="bk-loading"><div class="bk-spinner"></div><p>Đang tải...</p></div>
        </div>
        <div class="bk-modal-footer" id="detailFooter"></div>
    </div>
</div>

<!-- ══ MODAL: XÁC NHẬN ══ -->
<div class="bk-modal-overlay" id="confirmModalOverlay" onclick="closeConfirmModal(event)">
    <div class="bk-modal-sm" onclick="event.stopPropagation()">
        <div class="bk-confirm-icon" id="confirmIcon">✅</div>
        <h3 class="bk-confirm-title" id="confirmTitle">Xác nhận?</h3>
        <p class="bk-confirm-desc" id="confirmDesc"></p>
        <div class="bk-modal-footer">
            <button class="bk-btn-close" id="confirmCancelBtn" onclick="closeConfirmModalDirect()">Hủy bỏ</button>
            <button class="bk-btn-do-confirm" id="confirmOkBtn" onclick="doAction()">Xác nhận</button>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        const API   = 'http://localhost:5043/api';
        const TOKEN = '@Context.Session.GetString("AuthToken")';
        const H     = { 'Authorization': 'Bearer ' + TOKEN };
        let page = 1, pageSize = 10, totalItems = 0, pendingAction = null;

        async function fetchData() {
            setLoading(true); hideError();
            try {
                const qs  = buildQS();
                const res = await fetch(`${API}/admin/bookings?${qs}`, { headers: H });
                if (!res.ok) throw new Error(`Lỗi tải danh sách (${res.status})`);
                const data = await res.json();
                totalItems = data.totalItems ?? 0;
                renderStats(data.items ?? []);
                renderTable(data.items ?? []);
                renderPagination();
            } catch(e) { showError(e.message); }
            finally    { setLoading(false); }
        }

        function buildQS() {
            const p = new URLSearchParams({ page, pageSize });
            const s = document.getElementById('searchInput').value;
            const st= document.getElementById('statusFilter').value;
            const fd= document.getElementById('fromDate').value;
            const td= document.getElementById('toDate').value;
            if (s)  p.set('search',   s);
            if (st) p.set('status',   st);
            if (fd) p.set('fromDate', fd);
            if (td) p.set('toDate',   td);
            return p.toString();
        }

        function renderStats(items) {
            document.getElementById('hTotal').textContent     = totalItems;
            document.getElementById('hPending').textContent   = items.filter(b => b.status?.toLowerCase() === 'pending').length;
            document.getElementById('hConfirmed').textContent = items.filter(b => b.status?.toLowerCase() === 'confirmed').length;
            document.getElementById('hCancelled').textContent = items.filter(b => b.status?.toLowerCase() === 'cancelled').length;
        }

        function renderTable(items) {
            if (!items.length) { document.getElementById('tableBody').innerHTML = '<tr><td colspan="8" class="bk-empty-td">Không có booking nào</td></tr>'; return; }
            document.getElementById('tableBody').innerHTML = items.map((b, i) => {
                const st = b.status?.toLowerCase();
                return `<tr style="animation-delay:${i * 0.04}s">
                    <td class="bk-td-id">#${b.id}</td>
                    <td><span class="bk-cust-name">${b.customerName}</span></td>
                    <td class="bk-muted">${b.customerPhone}</td>
                    <td class="bk-muted">${fmtDate(b.createdAt)}</td>
                    <td><span class="bk-detail-badge">🏸 ${b.totalDetails} sân</span></td>
                    <td class="bk-td-money">${fmt(b.totalPrice)}</td>
                    <td>${statusBadge(b.status)}</td>
                    <td><div class="bk-action-btns">
                        <button class="bk-btn-view" onclick="openDetail(${b.id})">👁️ Chi tiết</button>
                        ${st === 'pending'    ? `<button class="bk-btn-confirm" onclick="askAction(${b.id},'confirm')">✅ Duyệt</button>` : ''}
                        ${st !== 'cancelled' ? `<button class="bk-btn-cancel"  onclick="askAction(${b.id},'cancel')">🚫 Hủy</button>`   : ''}
                    </div></td>
                </tr>`;
            }).join('');
        }

        function renderPagination() {
            const tp = Math.max(1, Math.ceil(totalItems / pageSize));
            if (page > tp) page = tp;
            const s = (page-1)*pageSize+1, e = Math.min(page*pageSize, totalItems);
            document.getElementById('pageInfo').textContent = totalItems ? `Hiển thị ${s}–${e} / ${totalItems}` : 'Không có dữ liệu';
            let btns = `<button class="bk-page-btn" onclick="goPage(${page-1})" ${page<=1?'disabled':''}>‹</button>`;
            for (let p=1; p<=tp; p++) {
                if (tp<=7 || p===1 || p===tp || Math.abs(p-page)<=1)
                    btns += `<button class="bk-page-btn ${p===page?'active':''}" onclick="goPage(${p})">${p}</button>`;
                else if (Math.abs(p-page)===2)
                    btns += `<button class="bk-page-btn" disabled>…</button>`;
            }
            btns += `<button class="bk-page-btn" onclick="goPage(${page+1})" ${page>=tp?'disabled':''}>›</button>`;
            document.getElementById('pageBtns').innerHTML = btns;
        }
        function goPage(p) { page = p; fetchData(); }
        function onPerPageChange(s) { pageSize = parseInt(s.value); page = 1; fetchData(); }

        async function openDetail(id) {
            document.getElementById('detailTitle').textContent = `Chi tiết Booking #${id}`;
            document.getElementById('detailBody').innerHTML    = '<div class="bk-loading"><div class="bk-spinner"></div><p>Đang tải...</p></div>';
            document.getElementById('detailFooter').innerHTML  = '';
            showModal('detailModalOverlay');
            try {
                const res = await fetch(`${API}/admin/bookings/${id}`, { headers: H });
                if (!res.ok) throw new Error('Không tải được chi tiết');
                const b = await res.json(), st = b.status?.toLowerCase();
                document.getElementById('detailBody').innerHTML = `
                    <div class="bk-detail-section">
                        <h4 class="bk-detail-section-title">👤 Thông tin khách hàng</h4>
                        <div class="bk-detail-grid">
                            ${di('Họ tên', b.customerName)}${di('Số điện thoại', b.customerPhone)}${di('Email', b.customerEmail||'—')}
                            ${di('Ngày tạo', fmtDate(b.createdAt))}${di('Tổng tiền', fmt(b.totalPrice), 'bk-detail-money')}${di('Trạng thái', statusBadge(b.status))}
                        </div>
                    </div>
                    <div class="bk-detail-section">
                        <h4 class="bk-detail-section-title">🏸 Danh sách sân đặt</h4>
                        <div style="overflow-x:auto"><table class="bk-table">
                            <thead><tr><th>Sân</th><th>Chi nhánh</th><th>Loại sân</th><th>Ngày chơi</th><th>Giờ chơi</th><th>Giá</th></tr></thead>
                            <tbody>${(b.details||[]).map((d,i) => `<tr style="animation-delay:${i*0.05}s">
                                <td><span class="bk-cust-name">${d.courtName}</span></td>
                                <td class="bk-muted">${d.branchName}</td>
                                <td><span class="bk-detail-badge">${d.courtTypeName}</span></td>
                                <td class="bk-muted">${new Date(d.playDate).toLocaleDateString('vi-VN')}</td>
                                <td class="bk-muted">${(d.startTime||'').slice(0,5)} – ${(d.endTime||'').slice(0,5)}</td>
                                <td class="bk-td-money">${fmt(d.priceSnapshot)}</td>
                            </tr>`).join('')}</tbody>
                        </table></div>
                    </div>`;
                let footer = `<button class="bk-btn-close" onclick="closeDetailModalDirect()">Đóng</button>`;
                if (st !== 'cancelled') {
                    if (st === 'pending') footer += `<button class="bk-btn-do-confirm" onclick="closeDetailModalDirect();askAction(${b.id},'confirm')">✅ Duyệt booking</button>`;
                    footer += `<button class="bk-btn-do-cancel-soft" onclick="closeDetailModalDirect();askAction(${b.id},'cancel')">🚫 Hủy booking</button>`;
                }
                document.getElementById('detailFooter').innerHTML = footer;
            } catch(e) { showError(e.message); closeDetailModalDirect(); }
        }
        function di(label, val, extra='') {
            return `<div class="bk-detail-item"><span class="bk-detail-label">${label}</span><span class="bk-detail-value ${extra}">${val}</span></div>`;
        }

        function askAction(id, action) {
            pendingAction = { id, action };
            const ok = action === 'confirm';
            document.getElementById('confirmIcon').textContent  = ok ? '✅' : '🚫';
            document.getElementById('confirmTitle').textContent = ok ? 'Xác nhận duyệt?' : 'Xác nhận hủy?';
            document.getElementById('confirmDesc').textContent  = ok ? `Bạn có chắc muốn duyệt booking #${id} không?` : `Bạn có chắc muốn hủy booking #${id}? Hành động này không thể hoàn tác!`;
            const btn = document.getElementById('confirmOkBtn');
            btn.className   = ok ? 'bk-btn-do-confirm' : 'bk-btn-do-cancel-hard';
            btn.textContent = ok ? '✅ Xác nhận duyệt' : '🚫 Xác nhận hủy';
            showModal('confirmModalOverlay');
        }

        async function doAction() {
            if (!pendingAction) return;
            setSaving(true);
            const { id, action } = pendingAction;
            const btn = document.getElementById('confirmOkBtn'), btnC = document.getElementById('confirmCancelBtn');
            btn.textContent = '⏳ Đang xử lý...'; btn.disabled = btnC.disabled = true;
            try {
                const res  = await fetch(`${API}/admin/bookings/${id}/${action}`, { method: 'PATCH', headers: H });
                const data = await res.json();
                if (!res.ok) throw new Error(data.message || `Thao tác thất bại (${res.status})`);
                closeConfirmModalDirect();
                showSuccess(data.message || (action === 'confirm' ? 'Đã duyệt booking!' : 'Đã hủy booking!'));
                await fetchData();
            } catch(e) { showError(e.message); closeConfirmModalDirect(); }
            finally    { setSaving(false); btn.disabled = btnC.disabled = false; }
        }

        function statusBadge(s) {
            const m = { pending:'<span class="bk-status bk-status-pending">⏳ Chờ xác nhận</span>', confirmed:'<span class="bk-status bk-status-confirmed">✅ Đã xác nhận</span>', cancelled:'<span class="bk-status bk-status-cancelled">🚫 Đã hủy</span>' };
            return m[s?.toLowerCase()] || `<span class="bk-status bk-status-pending">${s}</span>`;
        }
        function fmt(n)    { return new Intl.NumberFormat('vi-VN').format(Math.round(n||0)) + 'đ'; }
        function fmtDate(d){ return d ? new Date(d).toLocaleString('vi-VN',{day:'2-digit',month:'2-digit',year:'numeric',hour:'2-digit',minute:'2-digit'}) : '—'; }

        function setLoading(on) { document.getElementById('loadingWrap').style.display = on?'flex':'none'; document.getElementById('tableSection').style.display = on?'none':'block'; }
        function setSaving(on)  { document.getElementById('savingOverlay').classList.toggle('visible', on); }
        function showError(m)   { document.getElementById('errorMsg').textContent = '⚠️ '+m; document.getElementById('errorBanner').style.display = 'flex'; }
        function hideError()    { document.getElementById('errorBanner').style.display = 'none'; }
        function showSuccess(m) { document.getElementById('successMsg').textContent = m; document.getElementById('successBanner').style.display = 'flex'; setTimeout(() => document.getElementById('successBanner').style.display = 'none', 3500); }
        function showModal(id)  { document.getElementById(id).classList.add('visible'); }
        function hideModal(id)  { document.getElementById(id).classList.remove('visible'); }
        function closeDetailModal(e)       { if (e.target.id==='detailModalOverlay')  closeDetailModalDirect(); }
        function closeDetailModalDirect()  { hideModal('detailModalOverlay'); }
        function closeConfirmModal(e)      { if (e.target.id==='confirmModalOverlay') closeConfirmModalDirect(); }
        function closeConfirmModalDirect() { hideModal('confirmModalOverlay'); pendingAction = null; }
        function onSearch(inp) { document.getElementById('searchClear').style.display = inp.value?'block':'none'; page=1; fetchData(); }
        function clearSearch() { document.getElementById('searchInput').value=''; document.getElementById('searchClear').style.display='none'; page=1; fetchData(); }
        function onFilterChange() { page=1; fetchData(); }
        function handleLogout() { if (confirm('Bạn có chắc chắn muốn đăng xuất?')) window.location.href='/admin/login'; }

        fetchData();
    </script>
}
