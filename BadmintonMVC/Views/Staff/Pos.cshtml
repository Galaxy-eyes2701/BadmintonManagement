<div id="print-section"></div>

@section Scripts {
<script>
const API   = 'http://localhost:5043/api';
const token = '@Context.Session.GetString("AuthToken")';

let allProducts    = [];
let allCategories  = [];
let activeBookings = [];
let cart           = [];
let currentCatId   = '';
let selectedPayment = '';
let billData       = null;  // response từ /booking-bill
let remainingAmount = 0;    // số tiền thực phải thu (sau voucher)
let wiPayMethod    = '';

/* ══ INIT ══ */
async function init() {
    try {
        const hd = { 'Authorization':'Bearer '+token };
        const [pR, cR, bR] = await Promise.all([
            fetch(`${API}/products`,             { headers:hd }),
            fetch(`${API}/pos/categories`,       { headers:hd }),
            fetch(`${API}/staff/active-bookings`,{ headers:hd })
        ]);
        allProducts    = pR.ok ? await pR.json() : [];
        allCategories  = cR.ok ? await cR.json() : [];
        activeBookings = bR.ok ? await bR.json() : [];
        buildCatTabs();
        buildBookingDropdown();
        renderProducts();
        renderActionBtns();
    } catch(e) {
        document.getElementById('productGrid').innerHTML =
            `<div class="col-12 text-center text-danger p-4">❌ Lỗi: ${e.message}</div>`;
    }
}
const hd  = () => ({ 'Authorization':'Bearer '+token });
const hj  = () => ({ ...hd(), 'Content-Type':'application/json' });

/* ══ CATEGORIES ══ */
function buildCatTabs() {
    let html = `<button class="btn btn-sm cat-btn active" onclick="filterCat('',this)">Tất cả</button>`;
    allCategories.forEach(c =>
        html += `<button class="btn btn-sm cat-btn btn-outline-secondary"
                          onclick="filterCat(${c.id},this)">${c.name}</button>`);
    document.getElementById('catTabs').innerHTML = html;
}
function filterCat(id, btn) {
    currentCatId = id;
    document.querySelectorAll('.cat-btn').forEach(b => {
        b.classList.remove('active'); b.classList.add('btn-outline-secondary');
    });
    btn.classList.add('active'); btn.classList.remove('btn-outline-secondary');
    renderProducts();
}

/* ══ SẢN PHẨM ══ */
function renderProducts() {
    const q = document.getElementById('searchProd').value.toLowerCase();
    const list = allProducts.filter(p =>
        (!currentCatId || p.categoryId === parseInt(currentCatId)) &&
        p.name.toLowerCase().includes(q)
    );
    if (!list.length) {
        document.getElementById('productGrid').innerHTML =
            '<div class="col-12 text-center text-muted p-5">Không có sản phẩm nào</div>';
        return;
    }
    document.getElementById('productGrid').innerHTML = list.map(p => {
        const inCart  = cart.find(i => i.id === p.id);
        const soldOut = p.stockQuantity < 1;
        const cat     = allCategories.find(c => c.id === p.categoryId)?.name || '';
        return `
        <div class="col-6 col-md-4 col-lg-3">
            <div class="card product-card h-100 ${soldOut?'out-of-stock':''}"
                 onclick="${soldOut?'':'addToCart('+p.id+')'}" style="position:relative">
                ${inCart?`<span class="badge position-absolute top-0 end-0 m-1"
                                 style="background:#0f766e;font-size:11px;z-index:2">${inCart.qty}</span>`:''}
                <div class="card-body p-2 text-center">
                    <div style="height:80px;display:flex;align-items:center;justify-content:center;
                                background:#f8fafc;border-radius:8px;margin-bottom:8px;overflow:hidden">
                        ${p.imageUrl
                            ? `<img src="${p.imageUrl}" style="max-height:76px;max-width:100%;object-fit:contain"
                                    onerror="this.parentElement.innerHTML='<span style=font-size:32px>📦</span>'"/>`
                            : `<span style="font-size:32px">📦</span>`}
                    </div>
                    <div class="fw-semibold text-truncate" style="font-size:12px">${p.name}</div>
                    ${cat?`<div class="text-muted" style="font-size:10px">${cat}</div>`:''}
                    <div class="fw-bold text-primary mt-1" style="font-size:13px">${fmt(p.unitPrice)}</div>
                    <span class="badge ${p.stockQuantity>10?'bg-success':p.stockQuantity>0?'bg-warning text-dark':'bg-danger'}"
                          style="font-size:10px">
                        ${soldOut?'Hết hàng':'Còn '+p.stockQuantity}
                    </span>
                </div>
            </div>
        </div>`;
    }).join('');
}

/* ══ GIỎ HÀNG ══ */
function addToCart(id) {
    const p = allProducts.find(x => x.id === id);
    if (!p) return;
    const ex = cart.find(x => x.id === id);
    if (ex) {
        if (ex.qty >= p.stockQuantity) { alert('Đã đạt tối đa tồn kho!'); return; }
        ex.qty++;
    } else {
        cart.push({ id:p.id, name:p.name, price:p.unitPrice, qty:1 });
    }
    renderCart(); renderProducts(); renderActionBtns();
}
function updateQty(id, delta) {
    const item = cart.find(x => x.id === id);
    if (!item) return;
    item.qty += delta;
    if (item.qty <= 0) cart = cart.filter(x => x.id !== id);
    renderCart(); renderProducts(); renderActionBtns();
}
function clearCart() {
    if (!cart.length) return;
    if (!confirm('Xóa toàn bộ giỏ hàng?')) return;
    cart = []; renderCart(); renderProducts(); renderActionBtns();
}
function renderCart() {
    const total     = cart.reduce((s,x) => s+x.price*x.qty, 0);
    const itemCount = cart.reduce((s,x) => s+x.qty, 0);
    document.getElementById('totalDisplay').textContent = fmt(total);
    document.getElementById('cartCount').textContent    = itemCount + ' món';
    if (!cart.length) {
        document.getElementById('cartList').innerHTML =
            '<p class="text-muted small text-center mt-4 mb-0">Chưa có sản phẩm nào</p>';
        return;
    }
    document.getElementById('cartList').innerHTML = cart.map(x => `
        <div class="cart-item d-flex align-items-center gap-2">
            <div class="flex-grow-1" style="min-width:0">
                <div class="fw-semibold text-truncate" style="font-size:12px">${x.name}</div>
                <div class="text-muted" style="font-size:11px">${fmt(x.price)}</div>
            </div>
            <div class="d-flex align-items-center gap-1">
                <button class="btn btn-outline-secondary btn-sm px-2 py-0 lh-1"
                        style="font-size:16px" onclick="updateQty(${x.id},-1)">−</button>
                <span class="fw-bold px-1" style="min-width:20px;text-align:center">${x.qty}</span>
                <button class="btn btn-outline-secondary btn-sm px-2 py-0 lh-1"
                        style="font-size:16px" onclick="updateQty(${x.id},1)">+</button>
            </div>
            <div class="fw-bold text-end" style="min-width:68px;font-size:12px">${fmt(x.price*x.qty)}</div>
        </div>`).join('');
}

/* ══ BOOKING ══ */
function buildBookingDropdown() {
    document.getElementById('bookingSelect').innerHTML =
        '<option value="">-- Khách vãng lai (trả tiền ngay) --</option>' +
        activeBookings.map(b =>
            `<option value="${b.id}">${b.courtName} — ${b.customerName} (${b.time})</option>`
        ).join('');
}
function onBookingChange() {
    const sel = document.getElementById('bookingSelect');
    const val = sel.value;
    const box = document.getElementById('bookingInfo');
    if (val) {
        box.style.display = '';
        box.style.cssText = 'display:block;margin-top:8px;padding:8px;border-radius:8px;background:#f0fdf9;border:1px solid #a7f3d0';
        box.innerHTML = `<span class="text-success fw-semibold" style="font-size:12px">
            ✓ ${sel.options[sel.selectedIndex].text}<br/>
            <span class="text-muted fw-normal">Đồ uống sẽ tính chung lúc trả sân</span>
        </span>`;
    } else {
        box.style.display = 'none';
    }
    renderActionBtns();
}
function renderActionBtns() {
    const hasBooking = !!document.getElementById('bookingSelect').value;
    const hasCart    = cart.length > 0;
    document.getElementById('actionBtns').innerHTML = hasBooking ? `
        <button class="btn btn-outline-success w-100 mb-2 fw-semibold"
                onclick="addToBookingTab()" ${!hasCart?'disabled':''}>
            🧃 Thêm vào tab sân
        </button>
        <button class="btn fw-bold w-100"
                style="background:linear-gradient(135deg,#0f766e,#14b8a6);color:white;padding:12px"
                onclick="openCheckoutModal()">
            🏸 Tất toán sân
        </button>` : `
        <button class="btn btn-dark w-100 fw-bold" style="padding:12px"
                onclick="openWalkInModal()" ${!hasCart?'disabled':''}>
            💵 Thu tiền vãng lai
        </button>`;
}

/* ══ THÊM VÀO TAB SÂN ══ */
async function addToBookingTab() {
    if (!cart.length) return;
    const bookingId = parseInt(document.getElementById('bookingSelect').value);
    const res = await fetch(`${API}/pos/create-order`, {
        method:'POST', headers:hj(),
        body: JSON.stringify({
            bookingId,
            items: cart.map(i => ({ productId:i.id, quantity:i.qty }))
        })
    });
    if (!res.ok) { alert('Lỗi thêm vào tab!'); return; }
    const sel  = document.getElementById('bookingSelect');
    const name = sel.options[sel.selectedIndex].text.split('—')[0].trim();
    alert(`✅ Đã thêm ${cart.reduce((s,i)=>s+i.qty,0)} món vào tab của ${name}`);
    cart = [];
    renderCart(); renderProducts(); renderActionBtns();
}

/* ══ MODAL VÃNG LAI ══ */
function openWalkInModal() {
    if (!cart.length) return;
    const total = cart.reduce((s,i) => s+i.price*i.qty, 0);
    document.getElementById('wiTotal').textContent = fmt(total);
    wiPayMethod = '';
    ['cash','transfer','vnpay'].forEach(m => {
        document.getElementById('wi-'+m).style.display = 'none';
        document.getElementById('wi-opt-'+m).classList.remove('selected');
    });
    document.getElementById('wiError').classList.add('d-none');
    document.getElementById('wiTransferOk').checked = false;
    document.getElementById('wiVnpayLink').style.display = 'none';
    document.getElementById('wiBtnConfirm').textContent = '✅ Thu tiền';
    document.getElementById('wiBtnConfirm').onclick = confirmWalkIn;
    const info = encodeURIComponent('Vang lai '+Date.now());
    document.getElementById('wiQrImage').src =
        `https://img.vietqr.io/image/MB-9629122004-qr_only.png?amount=${total}&addInfo=${info}`;
    new bootstrap.Modal(document.getElementById('walkInModal')).show();
}
function wiSelect(m) {
    wiPayMethod = m;
    ['cash','transfer','vnpay'].forEach(x => {
        document.getElementById('wi-'+x).style.display = x===m?'':'none';
        document.getElementById('wi-opt-'+x).classList.toggle('selected', x===m);
    });
    if (m==='cash') { document.getElementById('wiCashGiven').focus(); wiCalcChange(); }
}
function wiSetCash(n) { document.getElementById('wiCashGiven').value=n; wiCalcChange(); }
function wiSetCashExact() {
    document.getElementById('wiCashGiven').value = cart.reduce((s,i)=>s+i.price*i.qty,0);
    wiCalcChange();
}
function wiCalcChange() {
    const total = cart.reduce((s,i)=>s+i.price*i.qty,0);
    const given = parseFloat(document.getElementById('wiCashGiven').value)||0;
    const el    = document.getElementById('wiChange');
    el.textContent = fmt(Math.max(given-total,0));
    el.style.color = given>=total?'#0f766e':'#dc2626';
}
function wiShowErr(msg) {
    const el = document.getElementById('wiError');
    el.textContent = '⚠️ '+msg; el.classList.remove('d-none');
}
async function confirmWalkIn() {
    const total = cart.reduce((s,i)=>s+i.price*i.qty,0);
    document.getElementById('wiError').classList.add('d-none');
    if (!wiPayMethod) { wiShowErr('Chọn phương thức!'); return; }
    if (wiPayMethod==='cash') {
        const given = parseFloat(document.getElementById('wiCashGiven').value)||0;
        if (given < total) { wiShowErr(`Tiền đưa (${fmt(given)}) chưa đủ!`); return; }
    }
    if (wiPayMethod==='transfer' && !document.getElementById('wiTransferOk').checked) {
        wiShowErr('Xác nhận đã nhận tiền!'); return;
    }
    if (wiPayMethod === 'vnpay') {
        try {
            const res  = await fetch(`${API}/vnpay/create-payment`, {
                method:'POST', headers:hj(),
                body: JSON.stringify({ amount:total, orderInfo:'Vang lai POS' })
            });
            const data = await res.json();
            document.getElementById('wiVnpayUrl').href = data.paymentUrl;
            document.getElementById('wiVnpayLink').style.display = '';
            document.getElementById('wiBtnConfirm').textContent = '✅ Hoàn tất';
            document.getElementById('wiBtnConfirm').onclick = () => {
                printWalkInBill();
                bootstrap.Modal.getInstance(document.getElementById('walkInModal')).hide();
                finishWalkIn();
            };
        } catch(e) { wiShowErr('Lỗi VNPay: '+e.message); }
        return;
    }
    const methodMap = { cash:'CASH', transfer:'TRANSFER' };
    const res = await fetch(`${API}/pos/create-order`, {
        method:'POST', headers:hj(),
        body: JSON.stringify({
            bookingId: null,
            paymentMethod: methodMap[wiPayMethod],
            items: cart.map(i=>({ productId:i.id, quantity:i.qty }))
        })
    });
    if (!res.ok) { wiShowErr('Lỗi lưu đơn!'); return; }
    printWalkInBill();
    bootstrap.Modal.getInstance(document.getElementById('walkInModal')).hide();
    finishWalkIn();
}
function finishWalkIn() {
    cart = []; renderCart(); renderProducts(); renderActionBtns();
}

/* ══ MODAL TẤT TOÁN SÂN ══ */
async function openCheckoutModal() {
    const bookingId = document.getElementById('bookingSelect').value;
    if (!bookingId) { alert('Chọn sân cần tất toán!'); return; }

    document.getElementById('billLoading').style.display = '';
    document.getElementById('billContent').style.display = 'none';
    selectedPayment = ''; billData = null; remainingAmount = 0;
    new bootstrap.Modal(document.getElementById('checkoutModal')).show();

    // Gọi booking-bill — field names đúng với backend:
    // courtTotal, posTotal, alreadyPaid, remainingAmount, customerName, loyaltyPoints, availableVouchers
    const res = await fetch(`${API}/staff/booking-bill/${bookingId}`, { headers:hd() });
    if (!res.ok) { alert('Lỗi lấy bill!'); return; }
    billData = await res.json();

    const newDrinkTotal = cart.reduce((s,i) => s+i.price*i.qty, 0);

    // remainingAmount từ backend đã tính: courtTotal + posTotal - alreadyPaid
    // Thêm nước mới vào
    remainingAmount = (billData.remainingAmount || 0) + newDrinkTotal;

    // Fill UI
    document.getElementById('ckCustomerInfo').textContent =
        `${billData.customerName} · ⭐${billData.loyaltyPoints} điểm`;

    document.getElementById('ckCourtTotal').textContent = fmt(billData.courtTotal);

    // Nước đã gọi trước (posTotal)
    if (billData.posTotal > 0) {
        document.getElementById('prevDrinkRow').style.cssText = 'display:flex!important;justify-content:space-between;margin-bottom:8px;padding-bottom:8px;border-bottom:1px solid #e2e8f0';
        document.getElementById('ckPosTotal').textContent  = fmt(billData.posTotal);
        document.getElementById('prevDrinkDetail').textContent = 'Đã order trong buổi';
    } else {
        document.getElementById('prevDrinkRow').style.cssText = 'display:none!important';
    }

    // Nước thêm lúc này
    if (newDrinkTotal > 0) {
        document.getElementById('newDrinkRow').style.cssText = 'display:flex!important;justify-content:space-between;margin-bottom:8px;padding-bottom:8px;border-bottom:1px solid #e2e8f0';
        document.getElementById('ckNewDrink').textContent   = fmt(newDrinkTotal);
        document.getElementById('newDrinkDetail').textContent =
            cart.map(i=>`${i.name} x${i.qty}`).join(', ');
    } else {
        document.getElementById('newDrinkRow').style.cssText = 'display:none!important';
    }

    // Loyalty points info
    if (billData.loyaltyPoints > 0) {
        document.getElementById('loyaltyRow').style.cssText = 'display:block!important;margin-bottom:8px;padding-bottom:8px;border-bottom:1px solid #e2e8f0';
        document.getElementById('loyaltyInfo').textContent =
            `Sau thanh toán sẽ được cộng ~${Math.floor(remainingAmount/10000)} điểm`;
    } else {
        document.getElementById('loyaltyRow').style.cssText = 'display:none!important';
    }

    // Vouchers
    const vSel = document.getElementById('voucherSelect');
    vSel.innerHTML = '<option value="">-- Không dùng voucher --</option>' +
        (billData.availableVouchers || []).map(v =>
            `<option value="${v.code}">${v.label}</option>`
        ).join('');
    document.getElementById('voucherApplied').style.display = 'none';

    updateRemaining(0); // reset discount

    // Reset payment
    ['cash','transfer','vnpay'].forEach(m => {
        document.getElementById('section-'+m).style.display = 'none';
        document.getElementById('opt-'+m).classList.remove('selected');
    });
    document.getElementById('paymentError').classList.add('d-none');
    document.getElementById('transferConfirmed').checked = false;
    document.getElementById('cashGiven').value = '';
    document.getElementById('changeDisplay').textContent = '0đ';
    document.getElementById('vnpayLinkWrap').style.display = 'none';
    updateQR(remainingAmount);

    document.getElementById('billLoading').style.display = 'none';
    document.getElementById('billContent').style.display = '';
}

function applyVoucher() {
    const vSel = document.getElementById('voucherSelect');
    const code = vSel.value;
    if (!code) {
        document.getElementById('voucherApplied').style.display = 'none';
        updateRemaining(0);
        return;
    }
    const voucher = (billData.availableVouchers||[]).find(v => v.code === code);
    if (!voucher) return;
    document.getElementById('voucherDiscount').textContent = fmt(voucher.discountAmount);
    document.getElementById('voucherApplied').style.display = '';
    updateRemaining(voucher.discountAmount);
}

function updateRemaining(discount) {
    const newDrink = cart.reduce((s,i) => s+i.price*i.qty, 0);
    const base     = (billData?.remainingAmount || 0) + newDrink;
    remainingAmount = Math.max(base - discount, 0);
    document.getElementById('ckGrandTotal').textContent = fmt(remainingAmount);
    document.getElementById('ckRemaining').textContent  = fmt(remainingAmount);
    updateQR(remainingAmount);
    if (selectedPayment === 'cash') calcChange();
}

function selectPayment(method) {
    selectedPayment = method;
    ['cash','transfer','vnpay'].forEach(m => {
        document.getElementById('section-'+m).style.display = m===method?'':'none';
        document.getElementById('opt-'+m).classList.toggle('selected', m===method);
    });
    document.getElementById('paymentError').classList.add('d-none');
    if (method==='cash') { setTimeout(()=>document.getElementById('cashGiven').focus(),100); calcChange(); }
    // Tạo link VNPay ngay khi chọn
    if (method==='vnpay') generateVnpayLink();
}

async function generateVnpayLink() {
    const bookingId = parseInt(document.getElementById('bookingSelect').value);
    document.getElementById('vnpayLoading').style.display  = '';
    document.getElementById('vnpayLinkWrap').style.display = 'none';
    document.getElementById('vnpayError').style.display    = 'none';
    if (document.getElementById('vnpayConfirmed'))
        document.getElementById('vnpayConfirmed').checked  = false;
    try {
        const res  = await fetch(`${API}/vnpay/create-payment`, {
            method:'POST', headers:hj(),
            body: JSON.stringify({
                amount:    remainingAmount,
                bookingId: bookingId || null,
                orderInfo: `Thanh toan san #${bookingId}`
            })
        });
        if (!res.ok) throw new Error(await res.text());
        const data   = await res.json();
        const payUrl = data.paymentUrl || data.PaymentUrl;
        if (!payUrl) throw new Error('Không nhận được link từ server');
        document.getElementById('vnpayUrl').href = payUrl;
        // QR từ link VNPay
        document.getElementById('vnpayQR').src =
            `https://api.qrserver.com/v1/create-qr-code/?size=180x180&data=${encodeURIComponent(payUrl)}`;
        document.getElementById('vnpayLoading').style.display  = 'none';
        document.getElementById('vnpayLinkWrap').style.display = '';
    } catch(e) {
        document.getElementById('vnpayLoading').style.display  = 'none';
        document.getElementById('vnpayErrorMsg').textContent   = e.message;
        document.getElementById('vnpayError').style.display    = '';
    }
}
function retryVnpay() { generateVnpayLink(); }

function setCash(n) { document.getElementById('cashGiven').value=n; calcChange(); }
function setCashExact() { document.getElementById('cashGiven').value=remainingAmount; calcChange(); }
function calcChange() {
    const given = parseFloat(document.getElementById('cashGiven').value)||0;
    const el = document.getElementById('changeDisplay');
    el.textContent = fmt(Math.max(given-remainingAmount,0));
    el.style.color = given>=remainingAmount?'#0f766e':'#dc2626';
}
function updateQR(amount) {
    const info = encodeURIComponent('Thanh toan san '+Date.now());
    document.getElementById('qrImage').src =
        `https://img.vietqr.io/image/MB-9629122004-qr_only.png?amount=${amount}&addInfo=${info}`;
    document.getElementById('qrAmountBadge').textContent = fmt(amount);
}
function showError(msg) {
    const el = document.getElementById('paymentError');
    el.textContent='⚠️ '+msg; el.classList.remove('d-none');
}

/* ══ XÁC NHẬN TẤT TOÁN ══ */
async function confirmCheckout() {
    document.getElementById('paymentError').classList.add('d-none');
    const bookingId  = parseInt(document.getElementById('bookingSelect').value);
    const voucherCode = document.getElementById('voucherSelect').value || null;

    if (!selectedPayment) { showError('Chọn phương thức thanh toán!'); return; }
    if (selectedPayment==='cash') {
        const given = parseFloat(document.getElementById('cashGiven').value)||0;
        if (given < remainingAmount) { showError(`Tiền đưa (${fmt(given)}) chưa đủ!`); return; }
    }
    if (selectedPayment==='transfer' && !document.getElementById('transferConfirmed').checked) {
        showError('Xác nhận đã nhận tiền!'); return;
    }

    const methodMap = { cash:'Tiền mặt', transfer:'Chuyển khoản', vnpay:'VNPay' };

    /* VNPay — link đã tạo sẵn khi chọn, chỉ cần check xác nhận */
    if (selectedPayment === 'vnpay') {
        const confirmed = document.getElementById('vnpayConfirmed');
        if (!confirmed || !confirmed.checked) {
            showError('Vui lòng xác nhận khách đã thanh toán thành công!');
            return;
        }
        // Checkout backend
        try {
            if (cart.length) {
                await fetch(`${API}/pos/create-order`, {
                    method:'POST', headers:hj(),
                    body: JSON.stringify({
                        bookingId,
                        items: cart.map(i=>({ productId:i.id, quantity:i.qty }))
                    })
                });
            }
            const r2 = await fetch(`${API}/staff/checkout/${bookingId}`, {
                method:'POST', headers:hj(),
                body: JSON.stringify({ PaymentMethod:'VNPay', VoucherCode:voucherCode })
            });
            if (!r2.ok) { showError('Lỗi checkout: '+await r2.text()); return; }
            const result = await r2.json();
            printCheckoutBill('VNPay', voucherCode, result.pointsAdded);
            bootstrap.Modal.getInstance(document.getElementById('checkoutModal')).hide();
            finishCheckout();
        } catch(e) { showError('Lỗi: '+e.message); }
        return;
    }

    /* Tiền mặt / Chuyển khoản */
    try {
        // 1. Lưu nước mới nếu có
        if (cart.length) {
            const r = await fetch(`${API}/pos/create-order`, {
                method:'POST', headers:hj(),
                body: JSON.stringify({
                    bookingId,
                    items: cart.map(i=>({ productId:i.id, quantity:i.qty }))
                })
            });
            if (!r.ok) { showError('Lỗi lưu đơn nước!'); return; }
        }

        // 2. Checkout — gửi đúng field backend cần: PaymentMethod + VoucherCode
        const r2 = await fetch(`${API}/staff/checkout/${bookingId}`, {
            method:'POST', headers:hj(),
            body: JSON.stringify({
                PaymentMethod: methodMap[selectedPayment],
                VoucherCode:   voucherCode
            })
        });
        if (!r2.ok) { showError('Lỗi checkout: '+await r2.text()); return; }
        const result = await r2.json();

        // In bill
        printCheckoutBill(methodMap[selectedPayment], voucherCode, result.pointsAdded);

        bootstrap.Modal.getInstance(document.getElementById('checkoutModal')).hide();
        finishCheckout();
        if (result.pointsAdded > 0) {
            setTimeout(() => alert(`⭐ Khách được cộng ${result.pointsAdded} điểm tích lũy!`), 500);
        }
    } catch(e) { showError('Lỗi: '+e.message); }
}

function finishCheckout() {
    cart = [];
    document.getElementById('bookingSelect').value = '';
    document.getElementById('bookingInfo').style.display = 'none';
    document.getElementById('btnConfirmCheckout').textContent = '✅ Xác nhận thanh toán';
    document.getElementById('btnConfirmCheckout').onclick = confirmCheckout;
    renderCart(); renderProducts(); renderActionBtns(); init();
}

/* ══ IN HÓA ĐƠN VÃNG LAI ══ */
function printWalkInBill() {
    const total  = cart.reduce((s,i) => s+i.price*i.qty, 0);
    const given  = parseFloat(document.getElementById('wiCashGiven').value)||0;
    const mLabel = { cash:'Tiền mặt', transfer:'Chuyển khoản', vnpay:'VNPay' };
    const now    = new Date().toLocaleString('vi-VN');
    const rows   = cart.map(i=>`
        <tr>
            <td style="padding:2px 0;font-size:11px">${i.name}</td>
            <td class="c" style="width:28px">${i.qty}</td>
            <td class="r" style="width:65px;font-size:11px">${fmt(i.price*i.qty)}</td>
        </tr>`).join('');
    document.getElementById('print-section').innerHTML = `
        <div style="font-family:'Courier New',monospace;font-size:12px;width:80mm">
            <div style="text-align:center;margin-bottom:8px">
                <div style="font-size:17px;font-weight:900">🏸 SÂN CẦU LÔNG FPT</div>
                <div style="font-size:10px">Khu Công Nghệ Cao Hòa Lạc — ĐT: 0123 456 789</div>
            </div>
            <div style="border-top:1px dashed #000;border-bottom:1px dashed #000;padding:4px 0;margin-bottom:6px">
                <div style="font-size:14px;font-weight:900;text-align:center">HÓA ĐƠN ĐỒ UỐNG</div>
                <div style="font-size:10px">Ngày: ${now} | Khách vãng lai</div>
            </div>
            <table style="width:100%;border-collapse:collapse">
                <thead><tr style="border-bottom:1px solid #888">
                    <th style="text-align:left;font-size:11px;padding:2px 0">Tên SP</th>
                    <th class="c" style="width:28px;font-size:11px">SL</th>
                    <th class="r" style="width:65px;font-size:11px">T.Tiền</th>
                </tr></thead>
                <tbody>${rows}</tbody>
            </table>
            <div style="border-top:1px dashed #000;margin-top:6px;padding-top:6px">
                <div style="display:flex;justify-content:space-between;font-size:15px;font-weight:900">
                    <span>TỔNG:</span><span>${fmt(total)}</span>
                </div>
                <div style="display:flex;justify-content:space-between;font-size:11px;color:#555">
                    <span>Thanh toán:</span><span>${mLabel[wiPayMethod]||wiPayMethod}</span>
                </div>
                ${wiPayMethod==='cash'?`
                <div style="display:flex;justify-content:space-between;font-size:11px">
                    <span>Tiền nhận:</span><span>${fmt(given)}</span>
                </div>
                <div style="display:flex;justify-content:space-between;font-size:12px;font-weight:700">
                    <span>Tiền thối:</span><span>${fmt(Math.max(given-total,0))}</span>
                </div>`:''}
            </div>
            <div style="text-align:center;margin-top:10px;padding-top:8px;
                        border-top:1px dashed #000;font-size:10px;color:#555">
                Cảm ơn! Hẹn gặp lại 🏸
            </div>
        </div>`;
    window.print();
}

/* ══ IN HÓA ĐƠN TẤT TOÁN SÂN ══ */
function printCheckoutBill(method, voucherCode, pointsAdded) {
    if (!billData) return;
    const now        = new Date().toLocaleString('vi-VN');
    const sel        = document.getElementById('bookingSelect');
    const courtLabel = sel.options[sel.selectedIndex].text;
    const newDrink   = cart.reduce((s,i) => s+i.price*i.qty, 0);
    const given      = parseFloat(document.getElementById('cashGiven').value)||0;
    const voucher    = voucherCode
        ? (billData.availableVouchers||[]).find(v=>v.code===voucherCode)
        : null;
    const discount   = voucher?.discountAmount || 0;

    const newRows = cart.map(i=>`
        <tr>
            <td style="padding:2px 0;font-size:11px">${i.name}</td>
            <td class="c" style="width:28px">${i.qty}</td>
            <td class="r" style="width:65px;font-size:11px">${fmt(i.price*i.qty)}</td>
        </tr>`).join('');

    document.getElementById('print-section').innerHTML = `
        <div style="font-family:'Courier New',monospace;font-size:12px;width:80mm">
            <div style="text-align:center;margin-bottom:8px">
                <div style="font-size:17px;font-weight:900">🏸 SÂN CẦU LÔNG FPT</div>
                <div style="font-size:10px">Khu Công Nghệ Cao Hòa Lạc — ĐT: 0123 456 789</div>
            </div>
            <div style="border-top:1px dashed #000;border-bottom:1px dashed #000;padding:4px 0;margin-bottom:6px">
                <div style="font-size:14px;font-weight:900;text-align:center">HÓA ĐƠN TẤT TOÁN SÂN</div>
                <div style="font-size:10px">
                    Ngày: ${now}<br/>
                    Khách: ${billData.customerName}<br/>
                    Sân: ${courtLabel}
                </div>
            </div>

            <div style="display:flex;justify-content:space-between;padding:3px 0;font-size:12px">
                <span>🏟️ Tiền sân</span>
                <span style="font-weight:700">${fmt(billData.courtTotal)}</span>
            </div>
            ${billData.posTotal>0?`
            <div style="display:flex;justify-content:space-between;padding:3px 0;font-size:12px">
                <span>🧃 Nước đã gọi</span>
                <span style="font-weight:700">${fmt(billData.posTotal)}</span>
            </div>`:''}
            ${newDrink>0?`
            <div style="border-top:1px dotted #ccc;margin-top:4px;padding-top:4px">
                <div style="font-size:10px;color:#666">Thêm lúc trả sân:</div>
                <table style="width:100%;border-collapse:collapse">${newRows}</table>
            </div>`:''}
            ${discount>0?`
            <div style="display:flex;justify-content:space-between;padding:3px 0;font-size:12px;color:#0f766e">
                <span>🎫 Voucher (${voucherCode})</span>
                <span style="font-weight:700">-${fmt(discount)}</span>
            </div>`:''}

            <div style="border-top:1px dashed #000;margin-top:6px;padding-top:6px">
                <div style="display:flex;justify-content:space-between;font-size:15px;font-weight:900">
                    <span>TỔNG PHẢI THU:</span><span>${fmt(remainingAmount)}</span>
                </div>
                <div style="display:flex;justify-content:space-between;font-size:11px;color:#555">
                    <span>Thanh toán:</span><span>${method}</span>
                </div>
                ${method==='Tiền mặt'?`
                <div style="display:flex;justify-content:space-between;font-size:11px">
                    <span>Tiền nhận:</span><span>${fmt(given)}</span>
                </div>
                <div style="display:flex;justify-content:space-between;font-size:12px;font-weight:700">
                    <span>Tiền thối:</span><span>${fmt(Math.max(given-remainingAmount,0))}</span>
                </div>`:''}
                ${pointsAdded>0?`
                <div style="font-size:11px;color:#0f766e;margin-top:4px">
                    ⭐ Cộng ${pointsAdded} điểm tích lũy
                </div>`:''}
            </div>
            <div style="text-align:center;margin-top:10px;padding-top:8px;
                        border-top:1px dashed #000;font-size:10px;color:#555">
                Cảm ơn quý khách! Hẹn gặp lại 🏸
            </div>
        </div>`;
    window.print();
}

function fmt(n) { return new Intl.NumberFormat('vi-VN').format(n||0)+'đ'; }
init();
</script>
}
