@{
    ViewData["Title"] = "Máy POS Bán hàng";
    ViewData["Page"] = "pos";
    Layout = "_StaffLayout";
}

<style>
    .product-card {
        cursor:pointer; transition:all .15s;
        border:2px solid #e2e8f0; border-radius:12px;
    }
    .product-card:hover {
        border-color:#0d7ff2; transform:translateY(-2px);
        box-shadow:0 4px 16px rgba(13,127,242,.15);
    }
    .product-card.out-of-stock { opacity:.5; cursor:not-allowed; pointer-events:none; }
    .cart-item { border-bottom:1px solid #f1f5f9; padding:10px 0; }
    .sidebar-pos {
        width:360px; min-width:360px; background:white;
        border-left:1px solid #e2e8f0; display:flex; flex-direction:column;
    }
    .cat-btn { border-radius:20px; font-size:13px; transition:all .15s; }
    .cat-btn.active { background:#0f766e; color:white; border-color:#0f766e; }
    .payment-option {
        cursor:pointer; transition:all .2s; border-radius:12px;
        border:2px solid #e2e8f0 !important;
    }
    .payment-option:hover  { background:#f0fdf9; border-color:#14b8a6 !important; }
    .payment-option.selected {
        background:#ecfdf5 !important; border-color:#0f766e !important;
        box-shadow:0 0 0 3px rgba(15,118,110,.15);
    }
    .payment-option.selected .pay-label { color:#0f766e; }

    @@media screen { #print-section { display:none !important; } }
    @@media print {
        @@page { margin:0; size:80mm auto; }
        body * { visibility:hidden !important; }
        #print-section, #print-section * { visibility:visible !important; }
        header, nav, .sidebar, aside, .top-bar, #pos-main-layout { display:none !important; }
        #print-section {
            display:block !important; position:absolute !important;
            left:0; top:0; width:80mm !important; padding:6mm !important;
            background:white !important; color:black !important;
            font-family:'Courier New',monospace !important; font-size:12px !important;
        }
        #print-section table { width:100%; border-collapse:collapse; }
        #print-section .r { text-align:right; }
        #print-section .c { text-align:center; }
    }
</style>

<div id="pos-main-layout" class="d-flex" style="height:calc(100vh - 64px)">

    <!-- ── LEFT: SẢN PHẨM ── -->
    <div class="flex-grow-1 d-flex flex-column overflow-hidden">
        <div class="p-3 border-bottom d-flex gap-2 flex-wrap align-items-center" style="background:white">
            <div id="catTabs" class="d-flex gap-2 flex-wrap">
                <button class="btn btn-sm cat-btn active" onclick="filterCat('',this)">Tất cả</button>
            </div>
            <div class="ms-auto">
                <input type="text" id="searchProd" class="form-control form-control-sm"
                       placeholder="🔍 Tìm sản phẩm..." oninput="renderProducts()" style="width:200px"/>
            </div>
        </div>
        <div class="flex-grow-1 overflow-auto p-3">
            <div class="row g-3" id="productGrid">
                <div class="col-12 text-center text-muted p-5">
                    <div class="spinner-border text-secondary mb-2"></div>
                    <div>Đang tải...</div>
                </div>
            </div>
        </div>
    </div>

    <!-- ── RIGHT: GIỎ HÀNG ── -->
    <aside class="sidebar-pos">
        <div class="p-3 border-bottom d-flex justify-content-between align-items-center">
            <h6 class="fw-bold mb-0">🛒 Giỏ hàng</h6>
            <button class="btn btn-outline-danger btn-sm" onclick="clearCart()">Xóa tất cả</button>
        </div>

        <div class="p-3 border-bottom">
            <label class="form-label small fw-semibold text-muted mb-1">🏟️ Gắn vào sân đang đánh</label>
            <select id="bookingSelect" class="form-select form-select-sm" onchange="onBookingChange()">
                <option value="">-- Khách vãng lai (trả tiền ngay) --</option>
            </select>
            <div id="bookingInfo" style="display:none"
                 class="mt-2 p-2 rounded-2 small text-success fw-semibold"
                 style="background:#f0fdf9;border:1px solid #a7f3d0"></div>
        </div>

        <div class="flex-grow-1 overflow-auto p-3" id="cartList">
            <p class="text-muted small text-center mt-4 mb-0">Chưa có sản phẩm nào</p>
        </div>

        <div class="p-3 border-top" style="background:#f8fafc">
            <div class="d-flex justify-content-between mb-1">
                <span class="text-muted small">Số mặt hàng:</span>
                <span class="small fw-semibold" id="cartCount">0</span>
            </div>
            <div class="d-flex justify-content-between mb-3">
                <span class="fw-bold">TỔNG ĐỒ UỐNG:</span>
                <strong class="text-danger fs-5" id="totalDisplay">0đ</strong>
            </div>
            <div id="actionBtns"></div>
        </div>
    </aside>
</div>

<!-- ════════ MODAL VÃNG LAI ════════ -->
