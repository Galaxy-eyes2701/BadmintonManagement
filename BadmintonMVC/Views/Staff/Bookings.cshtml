@{
    ViewData["Title"] = "Quản lý Booking";
    ViewData["Page"]  = "bookings";
    Layout = "_StaffLayout";
}

<div class="p-4">
    <!-- FILTER -->
    <div class="d-flex gap-3 mb-4 flex-wrap">
        <input type="text" id="searchInput" class="form-control" placeholder="🔍 Tìm tên / SĐT..." style="width:280px"
               oninput="loadBookings()"/>
        <select id="statusFilter" class="form-select" style="width:200px" onchange="loadBookings()">
            <option value="">Tất cả trạng thái</option>
            <option value="confirmed">✅ Đã xác nhận</option>
            <option value="completed">🏆 Hoàn thành</option>
            <option value="cancelled">❌ Đã hủy</option>
        </select>
    </div>

    <!-- BẢNG -->
    <div class="card shadow-sm">
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead style="background:#0f172a;color:white">
                    <tr>
                        <th>Mã đơn</th>
                        <th>Khách hàng</th>
                        <th>Thông tin sân</th>
                        <th>Tổng tiền</th>
                        <th>Trạng thái</th>
                        <th>Thao tác</th>
                    </tr>
                </thead>
                <tbody id="bookingBody">
                    <tr><td colspan="6" class="text-center p-4 text-muted">Đang tải...</td></tr>
                </tbody>
            </table>
        </div>

        <!-- PAGINATION -->
        <div class="p-3 border-top d-flex justify-content-between align-items-center">
            <span class="text-muted small" id="pageInfo"></span>
            <div class="d-flex gap-2">
                <button class="btn btn-outline-secondary btn-sm" onclick="changePage(-1)">« Trước</button>
                <span class="btn btn-sm disabled" id="pageNum">1</span>
                <button class="btn btn-outline-secondary btn-sm" onclick="changePage(1)">Tiếp »</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
const API = 'http://localhost:5043/api';
const token = '@Context.Session.GetString("AuthToken")';
let currentPage = 1;
let allBookings = [];

async function loadBookings() {
    currentPage = 1;
    const search = document.getElementById('searchInput').value;
    const status = document.getElementById('statusFilter').value;
    const res = await fetch(`${API}/staff/bookings?search=${search}&status=${status}`, {
        headers: { 'Authorization': 'Bearer ' + token }
    });
    allBookings = await res.json();
    renderTable();
}

function renderTable() {
    const perPage = 10;
    const start = (currentPage - 1) * perPage;
    const rows = allBookings.slice(start, start + perPage);

    if (!rows.length) {
        document.getElementById('bookingBody').innerHTML =
            '<tr><td colspan="6" class="text-center p-4 text-muted">Không có dữ liệu</td></tr>';
        return;
    }

    document.getElementById('bookingBody').innerHTML = rows.map((b, i) => `
        <tr>
            <td class="fw-bold text-muted">#${b.id}</td>
            <td>
                <div class="fw-bold">${b.customerName}</div>
                <small class="text-muted">${b.phone}</small>
            </td>
            <td>
                ${b.courtInfo ? `
                    <div class="fw-semibold text-primary">${b.courtInfo.courtName}</div>
                    <small class="text-muted">🕐 ${b.courtInfo.time} | ${new Date(b.courtInfo.date).toLocaleDateString('vi-VN')}</small>
                ` : '<span class="text-muted">—</span>'}
            </td>
            <td class="fw-bold">${fmt(b.totalPrice)}</td>
            <td>${badge(b.status)}</td>
            <td>
                ${b.status === 'confirmed' ? `
                    <button class="btn btn-danger btn-sm" onclick="cancelBooking(${b.id})">
                        🚫 Hủy lịch
                    </button>` : ''}
            </td>
        </tr>
    `).join('');

    const total = allBookings.length;
    const totalPages = Math.ceil(total / perPage);
    document.getElementById('pageInfo').textContent = `Hiển thị ${start+1}–${Math.min(start+perPage, total)} / ${total}`;
    document.getElementById('pageNum').textContent = `${currentPage} / ${totalPages}`;
}

function changePage(dir) {
    const perPage = 10;
    const totalPages = Math.ceil(allBookings.length / perPage);
    currentPage = Math.max(1, Math.min(totalPages, currentPage + dir));
    renderTable();
}

async function cancelBooking(id) {
    if (!confirm('Hủy lịch đặt sân này?')) return;
    const res = await fetch(`${API}/staff/bookings/${id}/cancel`, {
        method: 'PUT',
        headers: { 'Authorization': 'Bearer ' + token }
    });
    const data = await res.json();
    alert(data.message || 'Đã hủy!');
    loadBookings();
}

function badge(status) {
    const map = {
        confirmed: '<span class="badge bg-primary">✅ Đã xác nhận</span>',
        completed: '<span class="badge bg-success">🏆 Hoàn thành</span>',
        cancelled: '<span class="badge bg-danger">❌ Đã hủy</span>',
        pending:   '<span class="badge bg-warning text-dark">⏳ Chờ duyệt</span>',
    };
    return map[status] || `<span class="badge bg-secondary">${status}</span>`;
}

function fmt(n) {
    return new Intl.NumberFormat('vi-VN').format(n || 0) + 'đ';
}

loadBookings();
</script>
}