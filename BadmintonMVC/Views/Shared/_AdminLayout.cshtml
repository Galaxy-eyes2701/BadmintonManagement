<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <title>@ViewData["Title"] - Admin</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Nunito:wght@400;600;700;800;900&display=swap"
          rel="stylesheet" />
    <style>
            body {
                font-family: 'Nunito', sans-serif;
                background: #f1f5f9;
            }

            .sidebar {
                width: 260px;
                min-width: 260px;
                min-height: 100vh;
                background: #1a202c;
                flex-shrink: 0;
            }

            .sidebar .brand {
                background: linear-gradient(135deg, #0d5e58, #0f766e);
                padding: 20px 16px;
            }

            .sidebar .nav-link {
                color: #94a3b8;
                padding: 10px 16px;
                border-radius: 10px;
                margin: 2px 8px;
                font-weight: 600;
                font-size: 14px;
            }

            .sidebar .nav-link:hover {
                background: rgba(15, 118, 110, .15);
                color: #14b8a6;
            }

            .sidebar .nav-link.active {
                background: rgba(15, 118, 110, .2);
                color: #10b981;
            }

            .sidebar .section-label {
                font-size: 10px;
                color: #475569;
                text-transform: uppercase;
                letter-spacing: .08em;
                padding: 12px 24px 4px;
                font-weight: 700;
            }

            .top-bar {
                height: 64px;
                background: white;
                border-bottom: 1px solid #e2e8f0;
                padding: 0 28px;
                display: flex;
                align-items: center;
                justify-content: space-between;
            }

            .main-content {
                flex: 1;
                overflow-y: auto;
            }
    </style>
</head>

<body class="d-flex">

    <aside class="sidebar d-flex flex-column">
        <div class="brand">
            <div class="d-flex align-items-center gap-2">
                <span style="font-size:24px">🏸</span>
                <div>
                    <div class="text-white fw-black" style="font-size:15px;line-height:1">Badminton</div>
                    <div style="font-size:11px;color:rgba(255,255,255,.6)">Admin Panel</div>
                </div>
            </div>
        </div>

        <nav class="flex-grow-1 py-3">
            <div class="section-label">Quản lý</div>
            <a href="/Admin/AccountManager" class="nav-link @(ViewData["Page"]?.ToString() == "users" ? "active" : "")">
                👥 Quản lý tài khoản
            </a>
            <a href="/Admin/BranchCourt" class="nav-link @(ViewData["Page"]?.ToString() == "branch" ? "active" : "")">
                🏢 Cơ sở &amp; Sân
            </a>
            <a href="/Admin/Pricing" class="nav-link @(ViewData["Page"]?.ToString() == "pricing" ? "active" : "")">
                💰 Bảng giá
            </a>
            <a href="/Admin/Vouchers" class="nav-link @(ViewData["Page"]?.ToString() == "vouchers" ? "active" : "")">
                🎟️ Voucher
            </a>

            <div class="section-label mt-2">Thống kê</div>
            <a href="/Admin/Revenue" class="nav-link @(ViewData["Page"]?.ToString() == "revenue" ? "active" : "")">
                📊 Doanh thu
            </a>
            <a href="/Admin/Bookings" class="nav-link @(ViewData["Page"]?.ToString() == "bookings" ? "active" : "")">
                🏸 Quản lý Booking
            </a>
        </nav>

        <div class="p-3 border-top border-secondary">
            <div class="text-muted small mb-2 px-2">
                👤 @Context.Session.GetString("UserName")
            </div>
            <a href="/Auth/Logout" class="nav-link text-danger">🚪 Đăng xuất</a>
        </div>
    </aside>

    <div class="main-content d-flex flex-column w-100">
        <div class="top-bar">
            <h6 class="mb-0 fw-bold">@ViewData["Title"]</h6>
            <span class="badge" style="background:#0f766e">Admin</span>
        </div>
        <div class="flex-grow-1">
            @RenderBody()
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>

</html>