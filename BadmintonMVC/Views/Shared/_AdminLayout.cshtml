<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <title>@ViewData["Title"] - Admin</title>
    <link href="https://fonts.googleapis.com/css2?family=Nunito:wght@400;500;600;700;800;900&display=swap" rel="stylesheet" />
    <style>
        *, *::before, *::after {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        body {
            font-family: 'Nunito', sans-serif;
            background: #f1f5f9;
            min-height: 100vh;
        }

        /* ── HAMBURGER ─────────────────────────────────────────── */
        .sb-hamburger {
            font-size: 22px;
            background: linear-gradient(135deg, #0d5e58 0%, #0f766e 100%);
            border: none;
            color: white;
            cursor: pointer;
            position: fixed;
            top: 20px;
            left: 20px;
            z-index: 9999;
            width: 46px;
            height: 46px;
            border-radius: 12px;
            display: flex;
            align-items: center;
            justify-content: center;
            box-shadow: 0 4px 15px rgba(15,118,110,.35);
            transition: all .3s ease;
        }

            .sb-hamburger:hover {
                transform: translateY(-2px);
                box-shadow: 0 6px 20px rgba(15,118,110,.45);
                background: linear-gradient(135deg,#0a4a44,#0d5e58);
            }

            .sb-hamburger:active {
                transform: translateY(0);
            }

            .sb-hamburger.hidden {
                opacity: 0;
                visibility: hidden;
                pointer-events: none;
                transform: scale(.9);
            }

        /* ── OVERLAY ───────────────────────────────────────────── */
        .sb-overlay {
            position: fixed;
            inset: 0;
            background: rgba(0,0,0,.52);
            z-index: 997;
            backdrop-filter: blur(2px);
            opacity: 0;
            visibility: hidden;
            transition: all .35s ease;
        }

            .sb-overlay.visible {
                opacity: 1;
                visibility: visible;
            }

        /* ── SIDEBAR ───────────────────────────────────────────── */
        .sb-sidebar {
            position: fixed;
            left: -320px;
            top: 0;
            width: 300px;
            height: 100%;
            background: linear-gradient(160deg, #2d3748 0%, #1a202c 100%);
            color: white;
            transition: left .4s cubic-bezier(.4,0,.2,1), box-shadow .4s;
            z-index: 998;
            display: flex;
            flex-direction: column;
            box-shadow: none;
            border-right: 1px solid rgba(255,255,255,.08);
            overflow-y: auto;
            overflow-x: hidden;
        }

            .sb-sidebar::before {
                content: '';
                position: absolute;
                inset: 0;
                background: linear-gradient(135deg,rgba(15,118,110,.08) 0%,rgba(13,94,88,.08) 100%);
                pointer-events: none;
            }

            .sb-sidebar.open {
                left: 0;
                box-shadow: 4px 0 30px rgba(0,0,0,.4);
            }

            /* scrollbar */
            .sb-sidebar::-webkit-scrollbar {
                width: 5px;
            }

            .sb-sidebar::-webkit-scrollbar-track {
                background: rgba(255,255,255,.05);
            }

            .sb-sidebar::-webkit-scrollbar-thumb {
                background: linear-gradient(135deg,#14b8a6,#0f766e);
                border-radius: 3px;
            }

        /* ── SIDEBAR HEADER ────────────────────────────────────── */
        .sb-header {
            background: linear-gradient(135deg, #0d5e58 0%, #0f766e 100%);
            padding: 22px 22px 18px;
            flex-shrink: 0;
            border-bottom: 1px solid rgba(255,255,255,.1);
            position: relative;
        }

            .sb-header::after {
                content: '';
                position: absolute;
                bottom: 0;
                left: 0;
                right: 0;
                height: 1px;
                background: linear-gradient(90deg,transparent,rgba(255,255,255,.25),transparent);
            }

        .sb-close-btn {
            font-size: 15px;
            color: white;
            background: rgba(255,255,255,.18);
            border: none;
            cursor: pointer;
            padding: 7px 12px;
            border-radius: 8px;
            transition: all .25s;
            font-weight: 700;
            display: inline-block;
            margin-bottom: 12px;
            backdrop-filter: blur(8px);
        }

            .sb-close-btn:hover {
                background: rgba(255,255,255,.28);
                transform: translateX(-2px);
            }

        .sb-brand {
            display: flex;
            align-items: center;
            gap: 12px;
        }

        .sb-brand-icon {
            font-size: 26px;
            filter: drop-shadow(0 2px 6px rgba(0,0,0,.3));
        }

        .sb-brand-name {
            font-size: 22px;
            font-weight: 900;
            margin: 0;
            background: linear-gradient(135deg,#fff,#f7fafc);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
            text-shadow: none;
            line-height: 1.1;
        }

        .sb-brand-sub {
            font-size: 11px;
            color: rgba(255,255,255,.55);
            font-weight: 500;
            margin-top: 2px;
        }

        /* ── NAV MENU ──────────────────────────────────────────── */
        .sb-nav {
            padding: 16px 0 0;
            flex: 1;
            position: relative;
            z-index: 1;
        }

        .sb-section-label {
            font-size: 10px;
            color: #475569;
            text-transform: uppercase;
            letter-spacing: .08em;
            padding: 14px 26px 5px;
            font-weight: 700;
        }

        .sb-nav-item {
            display: flex;
            align-items: center;
            gap: 10px;
            padding: 14px 26px;
            color: #94a3b8;
            font-size: 14.5px;
            font-weight: 600;
            cursor: pointer;
            border-left: 4px solid transparent;
            transition: all .3s ease;
            text-decoration: none;
            position: relative;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
        }

            .sb-nav-item::before {
                content: '●';
                font-size: 7px;
                color: rgba(255,255,255,.3);
                flex-shrink: 0;
                transition: all .3s ease;
            }

            .sb-nav-item:hover {
                background: linear-gradient(135deg,rgba(15,118,110,.12),rgba(13,94,88,.12));
                border-left-color: #14b8a6;
                color: #e2e8f0;
                padding-left: 32px;
            }

                .sb-nav-item:hover::before {
                    color: #14b8a6;
                    transform: scale(1.3);
                }

            /* ACTIVE state — amber accent like React */
            .sb-nav-item.active {
                background: linear-gradient(135deg,rgba(15,118,110,.22),rgba(13,94,88,.22)) !important;
                border-left-color: #fbbf24 !important;
                color: #fbbf24 !important;
                font-weight: 800 !important;
                padding-left: 32px;
            }

                .sb-nav-item.active::before {
                    content: '♦' !important;
                    color: #fbbf24 !important;
                    font-size: 9px !important;
                }

                .sb-nav-item.active::after {
                    content: '';
                    position: absolute;
                    right: 18px;
                    top: 50%;
                    transform: translateY(-50%);
                    width: 6px;
                    height: 6px;
                    background: #fbbf24;
                    border-radius: 50%;
                    box-shadow: 0 0 10px rgba(251,191,36,.55);
                }

        /* stagger animation when sidebar opens */
        .sb-sidebar.open .sb-nav-item {
            animation: sb-slideIn .4s ease-out both;
        }

            .sb-sidebar.open .sb-nav-item:nth-child(1) {
                animation-delay: .05s;
            }

            .sb-sidebar.open .sb-nav-item:nth-child(2) {
                animation-delay: .10s;
            }

            .sb-sidebar.open .sb-nav-item:nth-child(3) {
                animation-delay: .15s;
            }

            .sb-sidebar.open .sb-nav-item:nth-child(4) {
                animation-delay: .20s;
            }

            .sb-sidebar.open .sb-nav-item:nth-child(5) {
                animation-delay: .25s;
            }

            .sb-sidebar.open .sb-nav-item:nth-child(6) {
                animation-delay: .30s;
            }

            .sb-sidebar.open .sb-nav-item:nth-child(7) {
                animation-delay: .35s;
            }
        @@keyframes sb-slideIn {
            from

        {
            opacity: 0;
            transform: translateX(-18px);
        }

        to {
            opacity: 1;
            transform: translateX(0);
        }

        }

        /* ── SIDEBAR FOOTER ────────────────────────────────────── */
        .sb-footer {
            padding: 12px 10px;
            border-top: 1px solid rgba(255,255,255,.08);
            flex-shrink: 0;
        }

            .sb-footer a {
                display: flex;
                align-items: center;
                gap: 10px;
                padding: 11px 18px;
                border-radius: 10px;
                color: #fc8181;
                font-size: 14px;
                font-weight: 700;
                text-decoration: none;
                transition: all .2s;
                border-left: 4px solid transparent;
            }

                .sb-footer a:hover {
                    background: rgba(239,68,68,.12);
                    border-left-color: #ef4444;
                    color: #fca5a5;
                }

        /* ── MAIN CONTENT ──────────────────────────────────────── */
        .sb-main {
            min-height: 100vh;
            display: flex;
            flex-direction: column;
        }

        /* ── RESPONSIVE ────────────────────────────────────────── */
        @@media (max-width: 768px) {
            .sb-hamburger {
                top: 16px;
                left: 16px;
                width: 42px;
                height: 42px;
                font-size: 19px;
            }

            .sb-sidebar {
                width: 280px;
                left: -300px;
            }

            .sb-nav-item {
                font-size: 14px;
                padding: 13px 22px;
            }

            .sb-brand-name {
                font-size: 19px;
            }
        }
    </style>
</head>

<body>

    <!-- ══ HAMBURGER ══ -->
    <button class="sb-hamburger" id="sbHamburger" onclick="openSidebar()" title="Mở menu">
        &#9776;
    </button>

    <!-- ══ OVERLAY ══ -->
    <div class="sb-overlay" id="sbOverlay" onclick="closeSidebar()"></div>

    <!-- ══ SIDEBAR ══ -->
    <aside class="sb-sidebar" id="sbSidebar">

        <div class="sb-header">
            <button class="sb-close-btn" onclick="closeSidebar()">&#171;&#171;</button>
            <div class="sb-brand">
                <span class="sb-brand-icon">🏸</span>
                <div>
                    <p class="sb-brand-name">Bảng điều khiển</p>
                    <p class="sb-brand-sub">Admin Panel</p>
                </div>
            </div>
        </div>

        <nav class="sb-nav">
            <div class="sb-section-label">Quản lý</div>

            <a href="/Admin/AccountManager"
               class="sb-nav-item @(ViewData["Page"]?.ToString() == "users" ? "active" : "")">
                👥 Quản lý tài khoản
            </a>
            <a href="/Admin/BranchCourt"
               class="sb-nav-item @(ViewData["Page"]?.ToString() == "branch" ? "active" : "")">
                🏢 Cơ sở &amp; Sân
            </a>
            <a href="/Admin/Pricing"
               class="sb-nav-item @(ViewData["Page"]?.ToString() == "pricing" ? "active" : "")">
                💰 Bảng giá
            </a>
            <a href="/Admin/Vouchers"
               class="sb-nav-item @(ViewData["Page"]?.ToString() == "vouchers" ? "active" : "")">
                🎟️ Voucher
            </a>
            <a href="/Admin/Bookings"
               class="sb-nav-item @(ViewData["Page"]?.ToString() == "bookings" ? "active" : "")">
                🏸 Quản lý đặt sân
            </a>

            <div class="sb-section-label">Thống kê</div>

            <a href="/Admin/Revenue"
               class="sb-nav-item @(ViewData["Page"]?.ToString() == "revenue" ? "active" : "")">
                📊 Doanh thu
            </a>
        </nav>
    </aside>

    <!-- ══ MAIN ══ -->
    <div class="sb-main">
        @RenderBody()
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

    <script>
        function openSidebar() {
            document.getElementById('sbSidebar').classList.add('open');
            document.getElementById('sbOverlay').classList.add('visible');
            document.getElementById('sbHamburger').classList.add('hidden');
        }
        function closeSidebar() {
            document.getElementById('sbSidebar').classList.remove('open');
            document.getElementById('sbOverlay').classList.remove('visible');
            document.getElementById('sbHamburger').classList.remove('hidden');
        }
        // Close on Escape key
        document.addEventListener('keydown', e => { if(e.key==='Escape') closeSidebar(); });
    </script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
