<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <title>@ViewData["Title"] - Staff</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700&display=swap" rel="stylesheet" />
    <style>
            body {
                font-family: 'Inter', sans-serif;
                background: #f8fafc;
            }

            .sidebar {
                width: 240px;
                min-height: 100vh;
                background: #0f172a;
                flex-shrink: 0;
            }

            .sidebar .nav-link {
                color: #94a3b8;
                padding: 10px 16px;
                border-radius: 8px;
                margin: 2px 8px;
            }

            .sidebar .nav-link:hover,
            .sidebar .nav-link.active {
                background: rgba(16, 185, 129, 0.1);
                color: #10b981;
            }

            .sidebar .nav-link .icon {
                margin-right: 8px;
            }

            .main-content {
                flex: 1;
                overflow-y: auto;
            }

            .top-bar {
                background: white;
                border-bottom: 1px solid #e2e8f0;
                padding: 0 24px;
                height: 64px;
                display: flex;
                align-items: center;
                justify-content: space-between;
            }
    </style>
</head>

<body class="d-flex">

    <!-- SIDEBAR -->
    <aside class="sidebar d-flex flex-column">
        <div class="p-3 border-bottom border-secondary">
            <div class="d-flex align-items-center gap-2">
                <div class="bg-success rounded p-1">
                    <svg width="20" height="20" fill="white" viewBox="0 0 24 24">
                        <path
                        d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z" />
                    </svg>
                </div>
                <span class="text-white fw-bold">Nhân viên</span>
            </div>
        </div>

        <nav class="flex-grow-1 py-3">
            <div class="px-3 mb-1" style="font-size:11px;color:#475569;text-transform:uppercase;letter-spacing:.05em">
                Đặt sân</div>
                <a href="/Staff/Schedule" class="nav-link @(ViewData["Page"]?.ToString()=="schedule"?"active":"")">📅
                    <span>Lịch sân hôm nay</span></a>
                    <a href="/Staff/Bookings" class="nav-link @(ViewData["Page"]?.ToString()=="bookings"?"active":"")">📋
                        <span>Quản lý Booking</span></a>
                        <a href="/Staff/FixedSchedule" class="nav-link @(ViewData["Page"]?.ToString()=="fixed"?"active":"")">🔁
                            <span>Lịch cố định</span></a>

                            <div class="px-3 mt-3 mb-1"
                                 style="font-size:11px;color:#475569;text-transform:uppercase;letter-spacing:.05em">Bán hàng</div>
                            <a href="/Staff/Pos" class="nav-link @(ViewData["Page"]?.ToString()=="pos"?"active":"")">🛒 <span>Máy
                                POS</span></a>
                                <a href="/Staff/Products" class="nav-link @(ViewData["Page"]?.ToString()=="products"?"active":"")">
                                    📦 <span>Quản lý kho nước</span>
                                </a>
                            </nav>

                            <div class="p-3 border-top border-secondary">
                                <a href="/Auth/Logout" class="nav-link text-danger">🚪 Đăng xuất</a>
                            </div>
                        </aside>

                        <!-- NỘI DUNG -->
                        <div class="main-content d-flex flex-column w-100">
                            <div class="top-bar">
                                <h6 class="mb-0 fw-bold">@ViewData["Title"]</h6>
                                <span class="text-muted small">👤 @Context.Session.GetString("UserName")</span>
                            </div>
                            <div class="flex-grow-1">
                                @RenderBody()
                            </div>
                        </div>

                        <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
                        @await RenderSectionAsync("Scripts", required: false)
                    </body>

                </html>