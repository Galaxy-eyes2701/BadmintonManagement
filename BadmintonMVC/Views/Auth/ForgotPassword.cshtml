@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Quen mat khau</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Nunito:wght@400;600;700;800;900&display=swap"
          rel="stylesheet" />
    <style>
        body {
            font-family: 'Nunito', sans-serif;
            background: linear-gradient(135deg, #0d5e58, #0f766e, #14b8a6);
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .card {
            border-radius: 16px;
            border: none;
            box-shadow: 0 20px 60px rgba(0, 0, 0, .2);
        }

        .btn-primary {
            background: linear-gradient(135deg, #0f766e, #14b8a6);
            border: none;
            font-weight: 700;
        }

        .btn-primary:hover {
            background: linear-gradient(135deg, #0d5e58, #0f766e);
        }

        .form-control:focus {
            border-color: #14b8a6;
            box-shadow: 0 0 0 3px rgba(20, 184, 166, .15);
        }
    </style>
</head>

<body>
    <div class="card p-4" style="width:420px">
        <div class="text-center mb-4">
            <span style="font-size:48px">🔐</span>
            <h4 class="fw-black mt-2 mb-0" style="color:#0f766e">Quen mat khau</h4>
            <p class="text-muted small">Nhap so dien thoai de nhan huong dan khoi phuc</p>
        </div>

        @if (ViewBag.Error != null)
        {
            <div class="alert alert-danger py-2 small">⚠️ @ViewBag.Error</div>
        }

        @if (ViewBag.Success != null)
        {
            <div class="alert alert-success py-2 small">✅ @ViewBag.Success</div>
        }

        <form method="post">
            <div class="mb-4">
                <label class="form-label fw-semibold">So dien thoai</label>
                <input type="text" name="phone" class="form-control" placeholder="0901234567" required autofocus />
            </div>
            <button type="submit" class="btn btn-primary w-100 py-2">Gui yeu cau</button>
        </form>

        <hr class="my-3" />
        <p class="text-center text-muted small mb-0">
            <a href="/Auth/Login" style="color:#0f766e">Quay lai dang nhap</a>
        </p>
    </div>
</body>

</html>
